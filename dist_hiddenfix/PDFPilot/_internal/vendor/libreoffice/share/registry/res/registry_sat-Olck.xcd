name="Fields"><node oor:name="expenseID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱷᱚᱨᱚᱡ  ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱷᱚᱨᱚᱡ  ID᱾</value></prop></node><node oor:name="expensetype"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱷᱚᱨᱚᱡ  ᱞᱮᱠᱟᱱ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱷᱚᱨᱚᱡ  ᱞᱮᱠᱟᱱᱠᱷᱚᱨᱚᱡ  ᱞᱮᱠᱟᱱ</value></prop></node><node oor:name="purpose"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱩᱫᱮᱥ ᱾ᱩᱫᱮᱥ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱩᱫᱮᱥ ᱾ᱩᱫᱮᱥ᱾</value></prop></node><node oor:name="employeeID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱟᱹᱢᱤᱭᱟ ᱠᱚ ID᱾ᱠᱟᱹᱢᱤᱭᱟᱹ ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱟᱹᱢᱤᱭᱟ ᱠᱚ ID᱾ᱠᱟᱹᱢᱤᱭᱟᱹ ID᱾</value></prop></node><node oor:name="datepurchased"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱛ ᱠᱤᱨᱤᱧ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱤᱨᱤᱧ ᱢᱟᱹᱦᱤᱫᱠᱤᱨᱤᱧ ᱢᱟᱹᱦᱤᱫ</value></prop></node><node oor:name="datesubmitted"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱚᱢᱟ  ᱢᱟᱹᱦᱤᱫᱡᱚᱢᱟ  ᱢᱟᱹᱦᱤᱫ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱚᱢᱟ ᱢᱟᱹᱦᱤᱫᱡᱚᱢᱟ ᱢᱟᱹᱦᱤᱫ</value></prop></node><node oor:name="amountspent"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱟᱹᱣᱲᱤ ᱠᱷᱚᱨᱚᱪᱠᱟᱹᱣᱲᱤ ᱠᱷᱚᱨᱚᱪ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱟᱹᱣᱲᱤ ᱠᱷᱚᱨᱚᱪᱠᱟᱹᱣᱲᱤ ᱠᱷᱚᱨᱚᱪ</value></prop></node><node oor:name="advanceamount"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱟᱲᱟᱝ ᱛᱮᱭᱟᱜ ᱠᱟᱣᱲᱤᱢᱟᱲᱟᱝ ᱛᱮᱭᱟᱜ ᱠᱟᱣᱲᱤ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱢᱟᱲᱟᱝ ᱛᱮᱭᱟᱜ ᱠᱟᱣᱲᱤᱢᱟᱲᱟᱝ ᱛᱮᱭᱟᱜ ᱠᱟᱣᱲᱤ</value></prop></node><node oor:name="paymentmethod"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱫᱚᱨᱢᱟ ᱣᱤᱫᱷᱟᱹᱱ᱾ᱫᱚᱨᱢᱟ ᱣᱤᱫᱷᱟᱱ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱫᱚᱨᱢᱟ ᱣᱤᱫᱷᱟᱹᱱ᱾ᱫᱚᱨᱢᱟ  ᱣᱤᱫᱷᱟᱱ᱾</value></prop></node><node oor:name="notes"><prop oor:name="Name"><value xml:lang="sat-Olck"