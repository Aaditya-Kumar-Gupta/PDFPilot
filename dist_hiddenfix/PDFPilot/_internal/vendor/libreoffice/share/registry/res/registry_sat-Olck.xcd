e="Name"><value xml:lang="sat-Olck">ᱛᱷᱟᱨ ᱞᱮᱠᱷᱟᱛᱷᱟᱨ ᱞᱮᱠᱷᱟ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱛᱷᱟᱨ ᱞᱮᱠᱷᱟ ᱾ᱛᱷᱟᱨ ᱞᱮᱠᱷᱟ᱾</value></prop></node><node oor:name="barcodenumber"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱦᱩᱨᱠᱟᱹᱲ ᱫᱟᱱᱟᱝ ᱪᱤᱱᱦᱟᱹᱦᱩᱨᱠᱟᱹᱲ ᱫᱟᱱᱟᱝ ᱪᱤᱱᱦᱟᱹ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱦᱩᱨᱠᱟᱹᱲ ᱫᱟᱱᱟᱝ ᱪᱤᱱᱦᱟᱹᱦᱩᱨᱠᱟᱹᱲ ᱫᱟᱱᱟᱝ ᱪᱤᱱᱦᱟᱹ</value></prop></node><node oor:name="dateacquired"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱧᱟᱢ ᱢᱟᱹᱦᱤᱫ ᱾ᱢᱟᱹᱦᱤᱫ ᱧᱟᱢ  ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱧᱟᱢ ᱢᱟᱹᱦᱤᱫ  ᱾ᱢᱟᱹᱦᱤᱫ ᱧᱟᱢ  ᱾</value></prop></node><node oor:name="datesold"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱫ ᱟᱠᱷᱨᱤᱧ᱾ᱢᱟᱹᱦᱤᱫ ᱟᱠᱷᱨᱤᱧ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱫ ᱟᱠᱷᱨᱤᱧ᱾ᱢᱟᱹᱦᱤᱫ ᱟᱠᱷᱨᱤᱧ᱾</value></prop></node><node oor:name="purchaseprice"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱤᱨᱤᱧ ᱜᱚᱱᱚᱝ ᱾ᱠᱤᱨᱤᱧ ᱜᱚᱱᱮᱝ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱤᱨᱤᱧ ᱜᱚᱱᱚᱝ ᱾ᱠᱤᱨᱤᱧ ᱜᱚᱱᱚᱝ ᱾</value></prop></node><node oor:name="depreciationmethod"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱜᱚᱱᱚᱝ ᱠᱚᱢ ᱣᱤᱫᱷᱟᱱᱜᱚᱱᱚᱝ ᱠᱚᱢ ᱣᱤᱫᱷᱟᱱ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱜᱚᱱᱚᱝ ᱠᱚᱢ ᱣᱤᱫᱷᱟᱱᱜᱚᱱᱚᱝ ᱠᱚᱢ ᱣᱤᱫᱷᱟᱱ</value></prop></node><node oor:name="depreciablelife"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱚᱢ ᱫᱟᱲᱮᱭᱟᱜ ᱡᱤᱣᱤ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱚᱢ ᱫᱟᱲᱮᱭᱟᱜ ᱡᱤᱣᱤᱠᱚᱢ ᱫᱟᱲᱮᱭᱟᱜ ᱡᱤᱣᱤ</value></prop></node><node oor:name="salvagevalue"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱤᱨᱯᱷᱟ ᱜᱚᱱᱚᱝᱥᱤᱨᱯᱷᱟ ᱜᱚᱱᱚᱝ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱤᱨᱯᱷᱟ ᱜᱚᱱᱚᱝᱥᱤᱨᱯᱷᱟ ᱜᱚᱱᱚᱝ</value></prop></node><node oor:name="currentvalue"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱱᱤᱛᱚᱜ ᱜᱚᱱᱚᱝ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱱᱤᱛᱚᱜᱟᱜ  ᱜᱚᱱᱚᱝᱱᱤᱛᱚᱜᱟᱜ  ᱜᱚᱱᱚᱝ</value></prop></node><node oor:name="comments