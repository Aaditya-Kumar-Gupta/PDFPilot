ᱭᱩᱢᱮᱱᱴ ᱠᱚ ᱨᱮᱭᱟᱜ ᱵᱟᱪᱷᱟᱣ ᱚᱱᱚᱞ) ᱵᱟᱝᱠᱷᱟᱱ ᱢᱤᱫ ᱫᱟᱹᱭᱠᱟᱹ (ᱠᱷᱟᱹᱞᱤ ᱰᱚᱠᱭᱩᱢᱮᱱᱴ ᱠᱚ ᱨᱮ)</value></prop></node><node oor:name="m06"><prop oor:name="Title" oor:type="xs:string"><value xml:lang="sat-Olck">ᱛᱷᱤᱨ ᱢᱮ</value></prop></node><node oor:name="m07"><prop oor:name="Title" oor:type="xs:string"><value xml:lang="sat-Olck">ᱚᱲᱟᱜ</value></prop></node><node oor:name="m08"><prop oor:name="Title" oor:type="xs:string"><value xml:lang="sat-Olck">ᱥᱟᱯᱷᱟ ᱥᱠᱨᱤᱱ</value></prop></node><node oor:name="m10"><prop oor:name="Title" oor:type="xs:string"><value xml:lang="sat-Olck">ᱞᱚᱜᱚ ᱠᱚᱢᱟᱱᱰ ᱞᱟᱭᱤᱱ (ᱠᱚᱢᱟᱱᱰ ᱮᱠᱡᱤᱠᱭᱩᱥᱚᱱ ᱞᱟᱹᱜᱤᱫ ᱮᱱᱴᱟᱨ ᱞᱤᱱ ᱢᱮ ᱵᱟᱝᱠᱷᱟᱱ ᱜᱚᱲᱚ ᱞᱟᱹᱜᱤᱫ ᱮᱯᱷ᱑)</value></prop></node><node oor:name="m09"><prop oor:name="Title" oor:type="xs:string"><value xml:lang="sat-Olck">ᱥᱟᱥᱟᱯᱲᱟᱣ ᱞᱮᱭᱟᱣᱩᱴ ᱥᱮᱴ ᱢᱮ, ᱯᱨᱚᱜᱽᱨᱟᱢ ᱯᱨᱚᱨᱩᱢ ᱢᱮ ᱟᱨᱵᱟᱝᱠᱷᱟᱱ ᱰᱚᱠᱭᱩᱢᱮᱱᱴ ᱨᱮᱭᱟᱜ ᱯᱟᱹᱨᱥᱤ ᱨᱮ ᱛᱚᱨᱡᱚᱢ ᱢᱮ</value></prop></node></node></node></node></oor:component-data><oor:component-data xmlns:install="http://openoffice.org/2004/installation" oor:name="Common" oor:package="org.openoffice.Office"><node oor:name="Menus"><node oor:name="New"><node oor:name="m0"><prop oor:name="Title"><value xml:lang="sat-Olck">~ᱚᱞ ᱰᱚᱠᱭᱩᱢᱮᱱᱴ</value></prop></node><node oor:name="m1"><prop oor:name="Title"><value xml:lang="sat-Olck">~ᱥᱯᱨᱮᱰᱥᱤᱴ</value></prop></node><node oor:name="m2"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱞᱮᱠᱷᱟ(~P)ᱩᱫᱩᱠ ᱥᱚᱫᱚᱨ (~P)</value></prop></node><node oor:name="m3"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱩᱱᱩᱫᱩᱠᱜᱟᱨ ᱪᱤᱛᱟᱹᱨ</value></prop></node><node oor:name="m4"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱮᱯ~ᱯᱷᱚᱨᱢᱩᱞᱟ</value></prop></node><node oor:name="m5"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱰᱟᱴᱟᱵᱮᱥ</value></prop></node><node oor:name="m7"><prop oor:name="Title"><value xml:lang="sat-Olck">~HTML ᱰᱚᱠᱭᱩᱢᱮᱱᱴ</value></prop></node><node oor:name="m8"><prop oor:name="Title"><value xml:lang="sat-Olck">~XMLᱛᱮᱭᱟᱨ ᱫᱚᱞᱤᱞ (~X)</value></prop></node><node oor:name="m10"><prop oor:name="Title"><value xml:lang="sat-Olck">~ᱞᱮᱵᱮᱞ ᱠᱚ</value></prop></node><node oor:name="m11"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱵᱤᱡᱤᱱᱮᱥ ᱠᱟᱨᱰ</value></prop></node><node oor:name="m13"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱢᱟᱥᱴᱚᱨ ᱰᱚᱠᱭᱩᱢᱮᱱᱴ</value></prop></node><node oor:name="m14"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱪᱷᱟᱸᱪ ᱠᱚ ...</value></prop></node></node><node oor:name="Wizard"><node oor:name="m0"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱪᱤᱴᱷᱤ  (~L)᱾᱾᱾</value></prop></node><node oor:name="m1"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱯᱷᱮᱠᱥ᱾(~F)</value></prop></node><node oor:name="m2"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱠᱟᱹᱢᱤ ᱦᱚᱨᱟ(~A) ᱾᱾᱾</value></prop></node><node oor:name="m11"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱰᱚᱠᱭᱩᱢᱮᱱᱴ ~ᱠᱚᱱᱵᱷᱟᱨᱴᱟᱨ...</value></prop></node><node oor:name="m14"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱴᱷᱤᱠᱟᱹᱱᱟ ᱰᱟᱴᱟ ᱥᱚᱨᱥ...</value></prop></node></node></node></oor:component-data><oor:component-data xmlns:install="http://openoffice.org/2004/installation" oor:name="DataAccess" oor:package="org.openoffice.Office"/><oor:component-data xmlns:install="http://openoffice.org/2004/installation" oor:package="org.openoffice.Office" oor:name="Embedding"><node oor:name="Verbs"><node oor:name="SHOW"><prop oor:name="VerbUIName"><value xml:lang="sat-Olck">ᱥᱟᱯᱲᱟᱣ (~E)ᱥᱟᱥᱟᱯᱲᱟᱣ (~E)</value></prop></node><node oor:name="OPEN"><prop oor:name="VerbUIName"><value xml:lang="sat-Olck">~ᱡᱷᱤᱡᱽ</value></prop></node><node oor:name="PROPERTIES"><prop oor:name="VerbUIName"><value xml:lang="sat-Olck">ᱥᱚᱢᱯᱚᱛᱤ ᱠᱚ...</value></prop></node><node oor:name="SAVECOPYAS"><prop oor:name="VerbUIName"><value xml:lang="sat-Olck">ᱱᱚᱠᱚᱞ ᱱᱚᱸᱠᱟ ᱥᱟᱸᱪᱟᱣ ᱢᱮ (~a)᱾᱾᱾ᱱᱚᱠᱚᱞ ᱞᱮᱠᱟ ᱥᱟᱧᱪᱟᱣ (~a)</value></prop></node></node><node oor:name="ObjectNames"><node oor:name="Calc"><prop oor:name="ObjectUIName"><value xml:lang="sat-Olck">%PRODUCTNAME 6᱾0 ᱥᱯᱨᱮᱰᱥᱤᱴ%PRODUCTNAME 6᱾0 ᱳᱥᱟᱨ ᱯᱟᱛᱟᱨ</value></prop></node><node oor:name="Chart"><prop oor:name="ObjectUIName"><value xml:lang="sat-Olck">%PRODUCTNAME %PRODUCTVERSION'</value></prop></node><node oor:name="Draw"><prop oor:name="ObjectUIName"><value xml:lang="sat-Olck">%PRODUCTNAME 6᱾0 ᱜᱟᱨ ᱪᱤᱛᱟᱹᱨ%PRODUCTNAME %PRODUCTVERSION ᱪᱤᱛᱟᱹᱛ ᱛᱮᱭᱟᱨ</value></prop></node><node oor:name="Impress"><prop oor:name="ObjectUIName"><value xml:lang="sat-Olck">%PRODUCTNAME 6᱾0 ᱯᱨᱥᱛᱩᱛᱤ%PRODUCTNAME 6᱾0 ᱩᱫᱩᱠ ᱥᱚᱫᱚᱨ</value></prop></node><node oor:name="Math"><prop oor:name="ObjectUIName"><value xml:lang="sat-Olck">%PRODUCTNAME %PRODUCTVERSION ᱯᱷᱚᱨᱢᱩᱞᱟ'</value></prop></node><node oor:name="Writer"><prop oor:name="ObjectUIName"><value xml:lang="sat-Olck">%PRODUCTNAME %PRODUCTVERSION ᱚᱞ'</value></prop></node></node></oor:component-data><oor:component-data oor:name="ExtendedColorScheme" oor:package="org.openoffice.Office"><node oor:name="EntryNames"><node oor:name="SunReportBuilder"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">ᱨᱤᱯᱚᱨᱴ ᱵᱤᱞᱰᱟᱨ</value></prop><node oor:name="Entries"><node oor:name="ReportHeader"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">ᱪᱚᱴᱟᱫ ᱨᱮᱯᱚᱨᱴ</value></prop></node><node oor:name="ReportFooter"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">ᱯᱷᱮᱰᱟᱫ ᱨᱮᱯᱚᱨᱴ</value></prop></node><node oor:name="PageHeader"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">ᱥᱟᱦᱴᱟ ᱪᱚᱴᱟᱫ</value></prop></node><node oor:name="PageFooter"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">ᱥᱟᱦᱴᱟ ᱯᱷᱮᱰᱟᱫ</value></prop></node><node oor:name="GroupHeader"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">ᱫᱚᱞ ᱪᱚᱴᱟᱫ</value></prop></node><node oor:name="GroupFooter"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">ᱫᱚᱞ ᱯᱷᱮᱰᱟᱫ</value></prop></node><node oor:name="ColumnHeader"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">Column Header</value></prop></node><node oor:name="ColumnFooter"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">Column Footer</value></prop></node><node oor:name="Detail"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">ᱯᱩᱨᱟᱹ ᱵᱤᱵᱨᱚᱱ (~c)</value></prop></node><node oor:name="OverlappedControl"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">Overlapped Control</value></prop></node><node oor:name="TextBoxBoundContent"><prop oor:name="DisplayName"><value xml:lang="sat-Olck">Text Box Bound Content</value></prop></node></node></node></node></oor:component-data><oor:component-data xmlns:install="http://openoffice.org/2004/installation" oor:name="FormWizard" oor:package="org.openoffice.Office"><node oor:name="FormWizard"><node oor:name="Styles"><node oor:name="style1"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱳᱡᱨᱟ ᱠᱟᱸᱴ ᱠᱟᱸᱴ ᱾ᱠᱟᱸᱴ ᱠᱟᱸᱴ ᱢᱟᱹᱭᱞᱟ ᱾</value></prop></node><node oor:name="style2"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱩᱸᱰ ᱯᱷᱟᱨᱪᱟ ᱞᱤᱞ ᱾ᱡᱷᱟᱞᱠᱟᱣ ᱞᱤᱞ᱾</value></prop></node><node oor:name="style3"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱦᱟᱞᱠᱟ ᱠᱟᱵᱽᱨᱟ</value></prop></node><node oor:name="style4"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱜᱟᱲᱦᱚᱜᱟᱲᱦᱚ</value></prop></node><node oor:name="style5"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱞᱮᱢᱵᱚ</value></prop></node><node oor:name="style6"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱟᱨᱮᱞ ᱞᱤᱞ ᱾</value></prop></node><node oor:name="style7"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱟᱵᱽᱨᱟ</value></prop></node><node oor:name="style8"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱫᱟᱜ</value></prop></node><node oor:name="style9"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱟᱨᱟᱜ</value></prop></node><node oor:name="style10"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱵᱮᱭᱚᱞᱮᱴ</value></prop></node></node></node></oor:component-data><oor:component-data xmlns:install="http://openoffice.org/2004/installation" oor:package="org.openoffice.Office" oor:name="PresentationMinimizer"><node oor:name="LastUsedSettings"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱨᱚᱡᱮᱠᱴᱟᱨ ᱟᱸᱥ ᱫᱚᱦᱚᱭᱤᱡ</value></prop></node><node oor:name="Settings"><node oor:name="Templates"><node oor:name="template1"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱤᱢᱮᱞ (᱙᱖ ᱰᱤᱯᱤᱟᱭ): ᱦᱟᱹᱴᱤᱧ ᱞᱟᱹᱜᱤᱫ ᱰᱚᱠᱭᱩᱢᱮᱱᱴ ᱥᱟᱭᱤᱡᱽ ᱠᱚᱢ ᱢᱮ</value></prop></node><node oor:name="template2"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱣᱮᱵᱽ (᱑᱕᱐ ᱰᱤᱯᱤᱟᱭ): ᱣᱮᱵᱽ ᱥᱟᱦᱴᱟ ᱟᱨ ᱯᱨᱚᱡᱮᱠᱴᱚᱨ ᱞᱟᱹᱜᱤᱫ ᱱᱟᱯᱟᱭ</value></prop></node><node oor:name="template3"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱪᱷᱟᱯᱟ (᱓᱐᱐ ᱰᱤᱯᱤᱟᱭ): ᱵᱤᱥᱛᱤ ᱪᱷᱟᱯᱟ ᱟᱨ ᱥᱠᱨᱤᱱ ᱨᱮ ᱵᱷᱟᱹᱜᱤ ᱜᱩᱱ</value></prop></node><node oor:name="template4"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱪᱮᱛᱟᱱ ᱯᱟᱹᱛᱭᱟᱹᱣᱟᱱᱺ ᱟᱥᱚᱞ ᱪᱤᱛᱟᱹᱨ ᱨᱮᱭᱟᱜ ᱜᱩᱱ ᱨᱟᱠᱷᱟ ᱫᱚᱦᱚᱭᱟᱭ</value></prop></node></node></node></oor:component-data><oor:component-data xmlns:install="http://openoffice.org/2004/installation" oor:package="org.openoffice.Office" oor:name="PresenterScreen"><node oor:name="PresenterScreenSettings"><node oor:name="ToolBars"><node oor:name="ToolBar"><node oor:name="Entries"><node oor:name="a"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱛᱟᱭᱚᱢ ᱥᱮᱫᱟᱜ (~w)ᱞᱟᱦᱟ ᱛᱮᱭᱟᱜ</value></prop></node></node><node oor:name="b"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱤᱱᱟᱹ ᱛᱟᱭᱚᱢ</value></prop></node></node><node oor:name="c"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱠᱷᱟᱴᱚ ᱚᱞ ᱠᱚ ᱾ᱠᱷᱟᱴᱚ ᱵᱤᱪᱟᱨ᱾</value></prop></node></node><node oor:name="d"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱥᱟᱞᱟᱤᱰᱥᱟᱞᱟᱤᱰ ᱠᱚ</value></prop></node></node><node oor:name="k"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱛᱷᱤᱨ</value></prop></node><node oor:name="Selected"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱫᱚᱦᱲᱟ ᱪᱟᱹᱞᱩᱭ ᱢᱮ</value></prop></node><node oor:name="MouseOverSelected"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱫᱚᱦᱲᱟ ᱪᱟᱹᱞᱩᱭ ᱢᱮ</value></prop></node></node><node oor:name="l"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱫᱚᱦᱲᱟ ᱪᱟᱹᱞᱩᱭ ᱢᱮ</value></prop></node></node><node oor:name="n"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱵᱚᱫᱚᱞ</value></prop></node></node><node oor:name="p"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱜᱚᱲᱚ</value></prop></node></node><node oor:name="r"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱵᱟᱹᱜᱤ</value></prop></node></node></node></node><node oor:name="NotesToolBar"><node oor:name="Entries"><node oor:name="a"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱦᱩᱰᱤᱧ ᱢᱟᱨᱟᱝ ᱦᱚᱪᱚ᱾</value></prop></node></node></node></node></node><node oor:name="Buttons"><node oor:name="SlideSorterCloser"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱵᱚᱸᱫᱚᱵᱚᱸᱫ ᱢᱮ</value></prop></node><node oor:name="NotesViewCloser"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱵᱚᱸᱫᱚᱵᱚᱸᱫ ᱢᱮ</value></prop></node><node oor:name="HelpViewCloser"><prop oor:name="Text"><value xml:lang="sat-Olck">ᱵᱚᱸᱫᱚᱵᱚᱸᱫ ᱢᱮ</value></prop></node></node><node oor:name="HelpView"><node oor:name="HelpStrings"><node oor:name="a"><prop oor:name="Left"><value xml:lang="sat-Olck">ᱞᱮᱸᱜᱟ ᱚᱛᱟᱭ, ᱡᱚᱡᱚᱢ ᱥᱮ ᱞᱟᱛᱟᱨ ᱥᱟᱨ, ᱥᱯᱮᱥᱵᱟᱨ, ᱥᱟᱦᱴᱟ ᱞᱟᱛᱟᱨ, ᱮᱱᱴᱟᱨ, ᱨᱩᱣᱟᱹᱲ</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱤᱱᱟᱹ ᱛᱟᱭᱚᱢ ᱥᱟᱞᱟᱤᱰ, ᱟᱨ ᱵᱟᱝ ᱤᱱᱟᱹ ᱛᱟᱭᱚᱢ ᱯᱚᱨᱵᱷᱟᱣ</value></prop></node><node oor:name="b"><prop oor:name="Left"><value xml:lang="sat-Olck">ᱡᱚᱡᱚᱢ ᱚᱛᱟᱭ, ᱞᱮᱸᱜᱟ ᱥᱮ ᱪᱮᱛᱟᱱ ᱥᱟᱨ, ᱥᱟᱦᱴᱟ ᱪᱮᱛᱟᱱ, ᱯᱟᱹᱪᱷᱞᱟᱹ ᱴᱷᱟᱶ</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱛᱟᱭᱚᱢ ᱥᱮᱫᱟᱜ ᱥᱟᱞᱟᱤᱰ, ᱟᱨ ᱵᱟᱝ ᱛᱟᱭᱚᱢ ᱥᱮᱫᱟᱜ ᱯᱚᱨᱵᱷᱟᱣ</value></prop></node><node oor:name="c"><prop oor:name="Left"><value xml:lang="sat-Olck">'ᱯᱤ'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱠᱚᱞᱚᱢ ᱞᱮᱠᱟᱛᱮ ᱢᱟᱣᱩᱥ ᱯᱚᱭᱮᱱᱴᱟᱨ ᱵᱮᱵᱷᱟᱨ ᱢᱮ</value></prop></node><node oor:name="d"><prop oor:name="Left"><value xml:lang="sat-Olck">ᱳᱲᱟᱜ</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱯᱟᱹᱦᱤᱞ ᱥᱟᱞᱟᱤᱰ</value></prop></node><node oor:name="e"><prop oor:name="Left"><value xml:lang="sat-Olck">ᱢᱩᱪᱟᱹᱫᱢᱩᱪᱟᱫ</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱢᱩᱪᱟᱹᱫ ᱥᱟᱞᱟᱤᱰ</value></prop></node><node oor:name="f"><prop oor:name="Left"><value xml:lang="sat-Olck">'ᱮ'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱥᱞᱟᱭᱤᱰ ᱨᱮ ᱥᱟᱱᱟᱢ ᱠᱟᱹᱢᱤ ᱢᱤᱴᱟᱣ ᱢᱮ</value></prop></node><node oor:name="g"><prop oor:name="Left"><value xml:lang="sat-Olck">ᱳᱨᱟᱯᱟᱨᱤ-ᱥᱟᱦᱴᱟ ᱪᱮᱛᱟᱱ</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱛᱟᱭᱚᱢ ᱥᱮᱫᱟᱜ ᱥᱟᱞᱟᱤᱰ ᱵᱮᱜᱚᱨ ᱯᱚᱨᱵᱷᱟᱣ ᱠᱚ</value></prop></node><node oor:name="h"><prop oor:name="Left"><value xml:lang="sat-Olck">ᱮᱯᱮᱴᱟᱜ-ᱥᱟᱦᱴᱟ ᱞᱟᱛᱟᱨ</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱤᱱᱟ ᱛᱟᱭᱚᱢ ᱥᱟᱞᱟᱤᱰ ᱵᱮᱜᱚᱨ ᱯᱚᱨᱵᱷᱟᱣ ᱛᱮ</value></prop></node><node oor:name="j"><prop oor:name="Left"><value xml:lang="sat-Olck">'B', '᱾'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱟᱰᱚᱝ ᱧᱮᱞᱚᱜ ᱱᱟᱯ</value></prop></node><node oor:name="k"><prop oor:name="Left"><value xml:lang="sat-Olck">'W', ','</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱥᱠᱨᱤᱱ ᱯᱩᱸᱰᱟᱜ ᱠᱚ/ᱵᱟᱝ ᱯᱩᱸᱰᱟᱜ ᱠᱚ</value></prop></node><node oor:name="m"><prop oor:name="Left"><value xml:lang="sat-Olck">Esc, '-'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱥᱟᱞᱟᱤᱰ ᱩᱫᱩᱠ ᱢᱩᱪᱟᱹᱫ</value></prop></node><node oor:name="o"><prop oor:name="Left"><value xml:lang="sat-Olck">ᱟᱫᱮᱨ ᱫᱟᱨᱟᱭ ᱛᱮ ᱞᱮᱠᱷᱟ ᱯᱟᱸᱡᱟ</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱳᱱᱟ ᱥᱟᱞᱟᱤᱰ ᱨᱮ ᱪᱟᱞᱟᱣ</value></prop></node><node oor:name="q"><prop oor:name="Left"><value xml:lang="sat-Olck">'G', 'S'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱦᱟᱨᱟ ᱨᱟᱠᱟᱯ/ᱩᱱᱩᱢ ᱠᱷᱟᱴᱚ ᱚᱞ ᱯᱷᱚᱱᱴ ᱨᱮᱭᱟᱜ ᱢᱟᱨᱟᱝ ᱛᱮᱫ</value></prop></node><node oor:name="r"><prop oor:name="Left"><value xml:lang="sat-Olck">'A', 'Z'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱠᱷᱟᱴᱚ ᱚᱞ ᱠᱚ ᱛᱮᱛᱨᱚ ᱪᱮᱛᱟᱱ/ᱞᱟᱛᱟᱨ</value></prop></node><node oor:name="s"><prop oor:name="Left"><value xml:lang="sat-Olck">'H', 'L'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱛᱟᱭᱚᱢ/ᱢᱟᱲᱟᱝ ᱥᱮᱫ ᱪᱟᱞᱟᱜ ᱞᱮᱠᱟ ᱠᱷᱟᱴᱚ ᱚᱞ ᱨᱮ ᱠᱮᱨᱮᱴ ᱞᱟᱲᱟᱣ</value></prop></node><node oor:name="u"><prop oor:name="Left"><value xml:lang="sat-Olck">Ctrl-'1' (~e)</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱩᱫᱩᱠ ᱥᱚᱫᱚᱨᱤᱡᱟᱜ ᱡᱤᱣᱤ ᱨᱟᱲᱮᱡ ᱩᱫᱩᱠ</value></prop></node><node oor:name="v"><prop oor:name="Left"><value xml:lang="sat-Olck">Ctrl-'2'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱩᱫᱩᱠ ᱥᱚᱫᱚᱨ ᱠᱷᱟᱴᱚ ᱚᱞ ᱠᱚ ᱩᱫᱩᱠ</value></prop></node><node oor:name="w"><prop oor:name="Left"><value xml:lang="sat-Olck">Ctrl-'3'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱥᱟᱞᱟᱤᱰ ᱧᱮᱞ ᱯᱟᱨᱚᱢᱟᱜ ᱠᱚ ᱩᱫᱩᱠ</value></prop></node><node oor:name="x"><prop oor:name="Left"><value xml:lang="sat-Olck">ᱠᱚᱱᱴᱨᱚᱞ-'᱔'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱢᱚᱱᱤᱴᱚᱨ ᱥᱣᱤᱪᱥ</value></prop></node><node oor:name="z"><prop oor:name="Left"><value xml:lang="sat-Olck">ᱠᱚᱱᱴᱨᱚᱞ-'ᱮ'</value></prop><prop oor:name="Right"><value xml:lang="sat-Olck">ᱯᱚᱭᱮᱱᱴᱟᱨ ᱠᱚᱞᱚᱱ ᱢᱚᱰ ᱞᱮᱠᱟᱛᱮ ᱵᱚᱱᱫᱚᱭ ᱢᱮ</value></prop></node></node></node></node><node oor:name="Presenter"><node oor:name="Views"><node oor:name="CurrentSlidePreview"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱱᱤᱛᱚᱜᱟᱜ ᱥᱟᱞᱟᱤᱰ (%CURRENT_SLIDE_NUMBER% %SLIDE_COUNT%ᱨᱮᱭᱟᱜ)</value></prop><prop oor:name="AccessibleTitle"><value xml:lang="sat-Olck">ᱱᱤᱛᱚᱜ ᱥᱞᱟᱭᱤᱰ (%CURRENT_SLIDE_NUMBER% ᱨᱮᱭᱟᱜ %SLIDE_COUNT%), %CURRENT_SLIDE_NAME%</value></prop><node oor:name="Strings"><node oor:name="ClickToExitPresentationText"><prop oor:name="String"><value xml:lang="sat-Olck">ᱩᱱᱩᱫᱩᱠ ᱠᱷᱚᱱ ᱵᱟᱦᱨᱮ ᱳᱲᱚᱠᱚᱜ ᱞᱟᱹᱜᱤᱫ ᱳᱛᱟᱭ ᱢᱮᱩᱫᱩᱠ ᱥᱚᱫᱚᱨ ᱠᱷᱚᱱ ᱵᱟᱦᱨᱮ ᱳᱰᱚᱜ ᱞᱟᱹᱜᱤᱫ ᱳᱛᱟ᱾᱾᱾</value></prop></node><node oor:name="ClickToExitPresentationTitle"><prop oor:name="String"><value xml:lang="sat-Olck">ᱱᱤᱛᱚᱜᱟᱜ ᱥᱟᱞᱟᱤᱰ (ᱢᱩᱪᱟᱹᱫ)</value></prop></node></node></node><node oor:name="NextSlidePreview"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱤᱱᱟ ᱛᱟᱭᱚᱢᱟᱜ ᱥᱟᱞᱟᱤᱰ</value></prop></node><node oor:name="NotesView"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱠᱷᱟᱴᱚ ᱚᱞ ᱠᱚ ᱾ᱠᱷᱟᱴᱚ ᱵᱤᱪᱟᱨ᱾</value></prop></node><node oor:name="SlideSorter"><prop oor:name="AccessibleTitle"><value xml:lang="sat-Olck">ᱥᱟᱞᱟᱤᱰ ᱧᱮᱞ ᱯᱟᱨᱚᱢᱟᱜ, %CURRENT_SLIDE_NAME%, %CURRENT_SLIDE_NUMBER% of %SLIDE_COUNT%ᱥᱟᱞᱟᱤᱰ ᱧᱮᱞ ᱯᱟᱨᱚᱢᱟᱜ, %CURRENT_SLIDE_NAME%, %CURRENT_SLIDE_NUMBER% of %SLIDE_COUNT%</value></prop></node><node oor:name="HelpView"><prop oor:name="Title"><value xml:lang="sat-Olck">ᱜᱚᱲᱚᱜᱚᱲᱚ(~H)</value></prop></node></node><node oor:name="Accessibility"><node oor:name="Console"><prop oor:name="String"><value xml:lang="sat-Olck">DUMMY_NO_MORE_USED</value></prop></node><node oor:name="Preview"><prop oor:name="String"><value xml:lang="sat-Olck">DUMMY_NO_MORE_USED</value></prop></node><node oor:name="Notes"><prop oor:name="String"><value xml:lang="sat-Olck">DUMMY_NO_MORE_USED</value></prop></node></node></node></oor:component-data><oor:component-data xmlns:install="http://openoffice.org/2004/installation" oor:name="TableWizard" oor:package="org.openoffice.Office"><node oor:name="TableWizard"><node oor:name="business"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱟᱨᱵᱟᱨ ᱦᱚᱲ</value></prop><node oor:name="Tables"><node oor:name="categories"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱦᱟᱹᱴᱤᱧ ᱨᱮ ᱛᱮᱭᱟᱨᱦᱟᱹᱴᱤᱧ ᱠᱚ᱾</value></prop><node oor:name="Fields"><node oor:name="categoryID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱦᱟᱹᱴᱤᱧ ID᱾ᱦᱟᱹᱴᱤᱧ ID ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱦᱟᱹᱴᱤᱧ ID᱾ᱦᱟᱹᱴᱤᱧ ID ᱾</value></prop></node><node oor:name="categoryname"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱦᱟᱹᱴᱤᱧ ᱧᱩᱛᱩᱢ ᱾ᱦᱟᱹᱴᱤᱧ ᱧᱩᱛᱩᱢ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱦᱟᱹᱴᱤᱧ ᱧᱩᱛᱩᱢ ᱾</value></prop></node></node></node><node oor:name="products"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱤᱱᱤᱥ ᱠᱚ</value></prop><node oor:name="Fields"><node oor:name="productID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱨᱚᱰᱟᱠᱴ ᱟᱭᱤ ᱰᱤ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱯᱨᱚᱰᱟᱠᱴ ᱟᱭᱤ ᱰᱤ</value></prop></node><node oor:name="productname"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱤᱱᱤᱥ ᱧᱩᱛᱩᱢ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱛᱮᱭᱟᱨ ᱳᱰᱚᱠ ᱧᱩᱛᱩᱢᱛᱮᱭᱟᱨ ᱳᱰᱚᱠ ᱧᱩᱛᱩᱢ</value></prop></node><node oor:name="productdescription"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱛᱮᱭᱟᱨ ᱳᱰᱚᱠ ᱵᱤᱵᱨᱚᱱᱛᱮᱭᱟᱨ ᱳᱰᱚᱠ ᱵᱤᱵᱨᱚᱱ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱛᱮᱭᱟᱨ ᱳᱰᱚᱠ ᱵᱤᱵᱨᱚᱱᱛᱮᱭᱟᱨ ᱳᱰᱚᱠ ᱵᱤᱵᱨᱚᱱ</value></prop></node><node oor:name="categoryID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱦᱟᱹᱴᱤᱧ ID᱾ᱦᱟᱹᱴᱤᱧ ID ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱦᱟᱹᱴᱤᱧ ID᱾ᱦᱟᱹᱴᱤᱧ ID ᱾</value></prop></node><node oor:name="supplierID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱮᱢᱚᱜᱤᱡᱟᱜ ID᱾ᱮᱢᱚᱜᱤᱡᱟᱜ ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱮᱢᱚᱜᱤᱡᱟᱜ ID᱾ᱮᱢᱚᱜᱤᱡᱟᱜ ID᱾</value></prop></node><node oor:name="serialnumber"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱛᱷᱟᱨ ᱞᱮᱠᱷᱟᱛᱷᱟᱨ ᱞᱮᱠᱷᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱛᱷᱟᱨ ᱞᱮᱠᱷᱟ ᱾ᱛᱷᱟᱨ ᱞᱮᱠᱷᱟ᱾</value></prop></node><node oor:name="unitsinstock"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱮᱞ ᱛᱷᱟᱨ ᱞᱮᱠᱷᱟ ᱡᱚᱜᱟᱣᱮᱞ ᱛᱷᱟᱨ ᱞᱮᱠᱷᱟ ᱡᱚᱜᱟᱣ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱮᱞᱮᱠᱷ ᱡᱚᱜᱟᱣᱮᱞᱮᱠᱷ ᱡᱚᱜᱟᱣ</value></prop></node><node oor:name="unitsonorder"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱮᱞᱮᱠᱷ ᱛᱷᱟᱨᱮᱞᱮᱠᱷ ᱛᱷᱟᱨ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱮᱞᱮᱠᱷ ᱛᱷᱟᱨᱮᱞᱮᱠᱷ ᱛᱷᱟᱨ</value></prop></node><node oor:name="unitprice"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱮᱞᱮᱠᱷ ᱜᱚᱱᱚᱝ ᱾ (~m)ᱮᱞᱮᱠᱷ ᱜᱚᱱᱚᱝ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱮᱞᱮᱠᱷ ᱜᱚᱱᱚᱝ ᱾ (~m)ᱮᱞᱮᱠᱷ ᱜᱚᱱᱚᱝ᱾</value></prop></node><node oor:name="reorderlevel"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱨᱤᱠᱚᱨᱰᱟᱠ ᱛᱟᱦᱨᱤᱠᱚᱨᱰᱟᱠ ᱛᱟᱦ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱨᱤᱠᱚᱨᱰ ᱛᱟᱦ</value></prop></node><node oor:name="discontinued"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱞᱮᱛᱟᱲ ᱨᱟᱹᱯᱩᱫᱞᱮᱛᱟᱲ ᱨᱟᱹᱯᱩᱫ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱞᱮᱛᱟᱲ ᱨᱟᱹᱯᱩᱫᱞᱮᱛᱟᱲ ᱨᱟᱹᱯᱩᱫ</value></prop></node><node oor:name="leadtime"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱟᱹᱭᱩᱨ ᱳᱠᱛᱚ ᱾ (~y)ᱮᱢᱚᱜ ᱠᱚ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱟᱹᱭᱩᱨ ᱳᱠᱛᱚ ᱾ (~y)ᱮᱢᱚᱜ ᱠᱚ ᱾</value></prop></node></node></node><node oor:name="suppliers"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱮᱢᱚᱜ ᱠᱚᱣᱟᱜᱮᱢᱚᱜ ᱠᱚᱣᱟᱜ</value></prop><node oor:name="Fields"><node oor:name="supplierID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱮᱢᱚᱜᱤᱡᱟᱜ ID᱾ᱮᱢᱚᱜᱤᱡᱟᱜ ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱮᱢᱚᱜᱤᱡᱟᱜ ID᱾ᱮᱢᱚᱜᱤᱡᱟᱜ ID᱾</value></prop></node><node oor:name="suppliername"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱮᱢᱚᱠ ᱠᱚᱣᱟᱜ ᱧᱩᱛᱩᱢᱮᱢᱚᱠ ᱠᱚᱣᱟᱜ ᱧᱩᱛᱩᱢ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱮᱢᱚᱠ ᱠᱚᱣᱟᱜ ᱧᱩᱛᱩᱢᱮᱢᱚᱠ ᱠᱚᱣᱟᱜ ᱧᱩᱛᱩᱢ</value></prop></node><node oor:name="contactname"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱚᱢᱯᱚᱠ ᱧᱩᱛᱩᱢᱥᱚᱢᱯᱚᱠ ᱧᱩᱛᱩᱢ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱚᱢᱯᱚᱠ ᱧᱩᱛᱩᱢ (~r)ᱥᱚᱢᱯᱚᱠ ᱧᱩᱛᱩᱢ</value></prop></node><node oor:name="contacttitle"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱚᱢᱯᱚᱠ ᱢᱩᱞ ᱧᱩᱛᱩᱢᱥᱚᱢᱯᱚᱠ ᱢᱩᱞ ᱧᱩᱛᱩᱢ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱚᱢᱯᱚᱠ ᱢᱩᱞ  ᱧᱩᱛᱩᱢᱥᱚᱢᱯᱚᱠ ᱢᱩᱞ  ᱧᱩᱛᱩᱢ</value></prop></node><node oor:name="address"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱴᱷᱤᱠᱟᱹᱱᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱴᱷᱤᱠᱟᱹᱱᱟ</value></prop></node><node oor:name="city"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱮᱸᱲᱟ ᱥᱚᱦᱚᱨ᱾ᱥᱦᱨ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱮᱸᱲᱟ ᱥᱚᱦᱚᱨ᱾ᱥᱦᱨ</value></prop></node><node oor:name="postalcode"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱰᱟᱠ ᱪᱤᱱᱦᱟᱹ ᱞᱮᱠᱷᱟ᱾ᱰᱟᱠ ᱪᱤᱱᱦᱟᱹ ᱞᱮᱠᱷᱟ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱰᱟᱠ ᱪᱤᱱᱦᱟᱹ ᱞᱮᱠᱷᱟ᱾ᱰᱟᱠ ᱪᱤᱱᱦᱟᱹ ᱞᱮᱠᱷᱟ᱾</value></prop><