ue xml:lang="sat-Olck">ᱜᱩᱥᱴᱤ ID᱾ᱜᱩᱥᱴᱤ  ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱜᱩᱥᱴᱤ ID᱾ᱜᱩᱥᱴᱤ  ID᱾</value></prop></node><node oor:name="registrationID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱧᱩᱛᱩᱢ ᱚᱞ ID</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱧᱩᱛᱩᱢ ᱚᱞ  ID</value></prop></node><node oor:name="projectID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱨᱚᱡᱮᱠᱴ ID᱾ᱯᱨᱚᱡᱮᱠᱴ  ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱯᱨᱚᱡᱮᱠᱴ ID᱾ᱯᱨᱚᱡᱮᱠᱴ  ID᱾</value></prop></node><node oor:name="paymentamount"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱫᱚᱨᱢᱟ ᱠᱟᱹᱣᱲᱤᱫᱚᱨᱢᱟ ᱠᱟᱹᱣᱲᱤ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱫᱚᱨᱢᱟ ᱠᱟᱹᱣᱲᱤᱫᱚᱨᱢᱟ ᱠᱟᱹᱣᱲᱤ</value></prop></node><node oor:name="paymentdate"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱫᱚᱨᱢᱟ  ᱣᱤᱫᱷᱟᱹᱱ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱫᱚᱨᱢᱟ ᱣᱤᱫᱷᱟᱹᱱᱫᱚᱨᱢᱟ ᱣᱤᱫᱷᱟᱹᱱ</value></prop></node><node oor:name="paymentmethod"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱫᱚᱨᱢᱟ ᱣᱤᱫᱷᱟᱹᱱ᱾ᱫᱚᱨᱢᱟ ᱣᱤᱫᱷᱟᱱ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱫᱚᱨᱢᱟ ᱣᱤᱫᱷᱟᱹᱱ᱾ᱫᱚᱨᱢᱟ  ᱣᱤᱫᱷᱟᱱ᱾</value></prop></node><node oor:name="checknumber"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱪᱮᱠ ᱞᱮᱠᱷᱟᱪᱮᱠ ᱞᱮᱠᱷᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱪᱮᱠ ᱞᱮᱠᱷᱟ (~n)ᱪᱮᱠ ᱞᱮᱠᱷᱟ</value></prop></node><node oor:name="creditcardtype"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱨᱮᱰᱤᱴ ᱠᱟᱨᱰ ᱞᱮᱠᱟᱱᱠᱨᱮᱰᱤᱴ ᱠᱟᱨᱰ ᱞᱮᱠᱟᱱ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱨᱮᱰᱤᱴ ᱠᱟᱨᱰ ᱞᱮᱠᱟᱱᱠᱨᱮᱰᱤᱴ ᱠᱟᱨᱰ ᱞᱮᱠᱟᱱ</value></prop></node><node oor:name="creditcardnumber"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱨᱮᱰᱤᱴ ᱠᱟᱨᱰ ᱞᱮᱠᱷᱟᱜᱨᱮᱰᱤᱴ ᱠᱟᱨᱰ ᱞᱮᱠᱷᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱤ ᱠᱟᱨᱰ ᱞᱮᱠᱷᱟᱥᱤ ᱠᱟᱨᱰ ᱞᱮᱠᱷᱟ</value></prop></node><node oor:name="cardholder"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱟᱨᱰ ᱧᱟᱹᱢᱤᱡ ᱾ᱠᱟᱨᱰ ᱧᱟᱹᱢᱤᱡ