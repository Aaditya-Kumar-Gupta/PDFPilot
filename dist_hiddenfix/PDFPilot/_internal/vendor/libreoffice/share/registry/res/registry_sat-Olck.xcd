 oor:name="shipperphonenumber"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱩᱞᱤᱡᱟᱜ ᱥᱟᱸᱜᱤᱧ ᱜᱟᱞ  ᱞᱮᱠᱷᱟᱠᱩᱞᱤᱡᱟᱜ ᱥᱟᱸᱜᱤᱧ ᱜᱟᱞ  ᱞᱮᱠᱷᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱥᱟᱸᱜᱤᱧ ᱜᱟᱞ ᱞᱮᱠᱷᱟ  ᱾ᱠᱩᱞᱤᱡᱟᱜ ᱥᱟᱸᱜᱤᱧ ᱜᱟᱞ  ᱞᱮᱠᱷᱟ  ᱾</value></prop></node><node oor:name="destinationaddress"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ  ᱛᱮᱭᱟᱜ ᱴᱷᱤᱠᱟᱹᱱᱟᱥᱟᱸᱜᱤᱧ  ᱛᱮᱭᱟᱜ ᱴᱷᱤᱠᱟᱹᱱᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ   ᱴᱷᱤᱠᱟᱹᱱᱟᱥᱟᱸᱜᱤᱧ   ᱴᱷᱤᱠᱟᱹᱱᱟ</value></prop></node><node oor:name="destinationcity"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ  ᱛᱮᱭᱟᱜ ᱥᱮᱸᱰᱟ ᱥᱚᱦᱚᱨᱥᱟᱸᱜᱤᱧ  ᱛᱮᱭᱟᱜ ᱥᱮᱸᱰᱟ ᱥᱚᱦᱚᱨ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ  ᱥᱮᱸᱲᱟ ᱥᱚᱦᱚᱨ</value></prop></node><node oor:name="destinationstateprovince"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ ᱯᱚᱱᱚᱛ ᱨᱟᱡᱥᱟᱸᱜᱤᱧ ᱯᱚᱱᱚᱛ ᱨᱟᱡ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ ᱯᱚᱱᱚᱛ ᱨᱟᱡᱥᱟᱸᱜᱤᱧ ᱯᱚᱱᱚᱛ ᱨᱟᱡ</value></prop></node><node oor:name="destinationpostalcode"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ ᱰᱟᱠ ᱞᱮᱠᱷᱟ ᱪᱤᱱᱦᱟᱹ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ ᱰᱟᱠ ᱞᱮᱠᱷᱟ ᱪᱤᱱᱦᱟᱹ</value></prop></node><node oor:name="destinationcountryregion"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ ᱫᱤᱥᱚᱢ ᱴᱷᱚᱴᱟᱥᱟᱸᱜᱤᱧ ᱫᱤᱥᱚᱢ ᱴᱷᱚᱴᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ ᱫᱤᱥᱚᱢ ᱴᱷᱚᱴᱟᱥᱟᱸᱜᱤᱧ ᱫᱤᱥᱚᱢ ᱴᱷᱚᱴᱟ</value></prop></node><node oor:name="arrivaldate"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱮᱴᱮᱨᱚᱠ ᱢᱟᱹᱦᱤᱫ (~n)</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱟᱸᱜᱤᱧ ᱫᱤᱥᱚᱢ ᱴᱷᱚᱴᱟᱥᱟᱸᱜᱤᱧ ᱫᱤᱥᱚᱢ ᱴᱷᱚᱴᱟ</value></prop></node><node oor:name="arrivaltime"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱮᱴᱚᱨᱚᱠ ᱳᱠᱛᱚᱥᱮᱴᱚᱨᱚᱠ ᱳᱠᱛᱚ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱮᱴᱚᱨᱚᱠ ᱳᱠᱛᱚᱥᱮᱴᱚᱨᱚᱠ ᱳᱠᱛᱚ</value></prop></node><node oor:name="currentlocation"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱱᱤᱛᱚᱜᱟᱜ ᱡᱟᱭᱜᱟ ᱴᱷᱟᱸᱣ (~v)</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱱᱤᱛᱚᱜᱟᱠ ᱡᱟᱭᱜᱟ ᱴᱷᱟᱸᱣᱱᱤᱛᱚᱜᱟᱠ ᱡᱟᱭᱜᱟ ᱴᱷᱟᱸᱣ</value></prop></node><node oor:name="packagedimensions"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱜᱷᱮᱸᱴ ᱢᱟᱯ ᱠᱚᱜᱷᱮᱸᱴ ᱢᱟᱯ ᱠᱚ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱜᱷᱮᱸᱴ ᱢᱟᱯ ᱠᱚᱜᱷᱮᱸᱴ ᱢᱟᱯ ᱠᱚ</value></prop></node><node oor:name="packageweight"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱜᱷᱮᱸᱴ ᱦᱟᱢᱟᱞ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱜᱷᱮᱸᱴ ᱦᱟᱢᱟᱞᱜᱷᱮᱸᱴ ᱦᱟᱢᱟᱞ</value></prop></node><node oor:name="pickuplocation"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱦᱟᱞᱟᱝ ᱡᱟᱭᱜᱟᱦᱟᱞᱟᱝ ᱡᱟᱭᱜᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱦᱟᱞᱟᱝ ᱡᱟᱭᱜᱟᱦᱟᱞᱟᱝ ᱡᱟᱭᱜᱟ</value></prop></node><node oor:name="pickupdate"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱦᱟᱞᱟᱝ ᱢᱟᱹᱦᱤᱫ᱾ᱦᱟᱞᱟᱝ ᱢᱟᱹᱦᱤᱫ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱦᱟᱞᱟᱝ ᱢᱟᱹᱦᱤᱫ᱾ᱦᱟᱞᱟᱝ ᱢᱟᱹᱦᱤᱫ ᱾</value></prop></node><node oor:name="pickuptime"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱦᱟᱞᱟᱝ ᱳᱠᱛᱚ ᱾ᱦᱟᱞᱟᱝ ᱳᱠᱛᱚ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱦᱟᱞᱟᱝ ᱳᱠᱛᱚ ᱾ᱦᱟᱞᱟᱝ ᱳᱠᱛᱚ ᱾</value></prop></node><node oor:name="receivedby"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱫᱟᱨᱟᱭ ᱛᱮ ᱦᱟᱛᱟᱣ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱫᱟᱨᱟᱭ ᱛᱮ ᱦᱟᱛᱟᱣ ᱾</value></prop></node><node oor:name="freightcharge"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱵᱚᱡᱷᱟ ᱜᱚᱱᱚᱝ ᱾ᱵᱷᱟᱲᱟ ᱜᱚᱱᱚᱝ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱵᱷᱟᱲᱟ ᱜᱚᱱᱚᱝᱵᱷᱟᱲᱟ ᱜᱚᱱᱚᱝ</value></prop></node><node oor:name="notes"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱱᱚᱴᱥ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱱᱚᱴᱥ</value></prop></node></node></node><node oor:name="assets"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱩᱸᱡᱤ ᱠᱚᱯᱩᱸᱡᱤ ᱠᱚ</value></prop><node oor:name="Fields"><node oor:name="