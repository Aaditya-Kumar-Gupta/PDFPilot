><value xml:lang="sat-Olck">ᱡᱟᱱᱟᱢ ᱢᱟᱹᱦᱤᱫ᱾ᱡᱟᱱᱟᱢ ᱢᱟᱹᱦᱤᱫ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱱᱟᱢ ᱢᱟᱹᱦᱤᱫ᱾ᱡᱟᱱᱟᱢ ᱢᱟᱹᱦᱤᱫ᱾</value></prop></node><node oor:name="datehired"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱫ  ᱵᱷᱟᱲᱟ᱾ᱢᱟᱹᱦᱤᱫ  ᱵᱷᱟᱲᱟ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱫ  ᱵᱷᱟᱲᱟ᱾ᱢᱟᱹᱦᱤᱫ  ᱵᱷᱟᱲᱟ᱾</value></prop></node><node oor:name="departmentID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱰᱤᱯᱟᱨᱴᱢᱮᱱᱴ ᱟᱭᱤ ᱰᱤ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱢᱟᱦᱟᱞ ID᱾</value></prop></node><node oor:name="salary"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱟᱣᱱᱟ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱯᱟᱣᱱᱟ ᱾</value></prop></node><node oor:name="billingrate"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱵᱤᱞ ᱫᱚᱨᱵᱤᱞ ᱫᱚᱨ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱵᱤᱞ ᱫᱚᱨᱵᱤᱞ ᱫᱚᱨ</value></prop></node><node oor:name="deductions"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱵᱷᱮᱜᱮᱫ ᱠᱚ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱵᱷᱮᱜᱮᱫ ᱠᱚ ᱾</value></prop></node><node oor:name="supervisorID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱧᱮᱸᱧᱮᱸᱞᱤᱡᱟᱜ ID</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱧᱮᱸᱧᱮᱸᱞᱤᱡᱟᱜ ID</value></prop></node><node oor:name="spousename"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱣᱟᱸᱭ ᱧᱩᱛᱩᱢ ᱾ᱡᱟᱣᱟᱸᱭ ᱧᱩᱛᱩᱢ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱣᱟᱸᱭ ᱧᱩᱛᱩᱢ ᱾ᱡᱟᱣᱟᱸᱭ ᱧᱩᱛᱩᱢ᱾</value></prop></node><node oor:name="officelocation"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱟᱹᱯᱷᱤᱥ ᱡᱟᱭᱜᱟᱟᱹᱯᱷᱤᱥ ᱡᱟᱭᱜᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱟᱹᱯᱷᱤᱥ ᱡᱟᱭᱜᱟᱟᱹᱯᱷᱤᱥ ᱡᱟᱭᱜᱟ</value></prop></node><node oor:name="photo"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱚᱦᱚᱨ ᱪᱤᱛᱟᱹᱨ᱾ᱢᱚᱦᱚᱨ ᱪᱤᱛᱟᱹᱨ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱢᱚᱦᱚᱨ ᱪᱤᱛᱟᱹᱨ᱾ᱢᱚᱦᱚᱨ ᱪᱤᱛᱟᱹᱨ᱾</value></prop></node><node oor:name="notes"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱱᱚᱴᱥ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱱᱚᱴᱥ</value></prop></node></node></node><node oor:name="orders"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱛᱷᱟᱨ ᱠᱚᱛᱷᱟᱨ ᱠᱚ</value></prop><node oor:name="Fields"><node oor:name="orderID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱛᱷᱟᱨ ᱠᱚ ID᱾ᱯᱚᱨᱢᱟᱥ ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱛᱷᱟᱨ ᱠᱚ ID᱾ᱯᱚᱨᱢᱟᱥ ID᱾</value></prop></node><node oor:name="customerID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱜᱚᱦᱨᱟᱜ ᱠᱚ ID᱾ᱜᱚᱦᱨᱟᱜ ᱠᱚᱣᱟᱜ ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱜᱚᱦᱨᱟᱜ ᱠᱚ ID᱾ᱜᱚᱦᱨᱟᱜ ᱠᱚᱣᱟᱜ ID᱾</value></prop></node><node oor:name="employeeID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱟᱹᱢᱤᱭᱟ ᱠᱚ ID᱾ᱠᱟᱹᱢᱤᱭᱟᱹ ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱟᱹᱢᱤᱭᱟ ᱠᱚ ID᱾ᱠᱟᱹᱢᱤᱭᱟᱹ ID᱾</value></prop></node><node oor:name="orderdate"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱚᱨᱢᱟᱹᱥ ᱢᱟᱹᱦᱤᱫ ᱾ᱯᱚᱨᱢᱟᱹᱥ ᱢᱟᱹᱦᱤᱫ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱯᱚᱨᱢᱟᱹᱥ ᱢᱟᱹᱦᱤᱫ ᱾ᱯᱚᱨᱢᱟᱹᱥ ᱢᱟᱹᱦᱤᱫ᱾</value></prop></node><node oor:name="purchaseordernumber"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱤᱨᱤᱧ ᱯᱚᱨᱢᱟᱥ ᱞᱮᱠᱷᱟ ᱾ᱠᱤᱨᱤᱧ ᱯᱚᱨᱢᱟᱥ ᱞᱮᱠᱷᱟ  ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱯᱚᱨᱢᱟᱹᱥ ᱢᱟᱹᱦᱤᱫ  ᱾ᱠᱤᱨᱤᱧ ᱯᱚᱨᱢᱟᱥ ᱞᱮᱠᱷᱟ ᱾</value></prop></node><node oor:name="requiredbydate"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱫ ᱞᱮᱠᱟ ᱛᱮ ᱞᱟᱹᱠᱛᱤᱢᱟᱹᱦᱤᱫ ᱞᱮᱠᱟ ᱛᱮ ᱞᱟᱹᱠᱛᱤ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱫ ᱞᱮᱠᱟ ᱛᱮ ᱞᱟᱹᱠᱛᱤᱢᱟᱹᱦᱤᱫ ᱞᱮᱠᱟ ᱛᱮ ᱞᱟᱹᱠᱛᱤ</value></prop></node><node oor:name="promisedbydate"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱫ ᱞᱮᱠᱟᱛᱮ ᱡᱚᱵᱟᱱᱢᱟᱹᱦᱤᱫ ᱞᱮᱠᱟᱛᱮ ᱡᱚᱵᱟᱱ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱚᱵᱟᱱ ᱢᱟᱹᱦᱤᱫᱡᱚᱵᱟᱱ ᱢᱟᱹᱦᱤᱫ</value></prop></node><node oor:name="shipname"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱧᱩᱛᱩᱢ ᱾ᱡᱟᱦᱟᱡ ᱧᱩᱛᱩᱢ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱧᱩᱛᱩᱢ ᱾ᱡᱟᱦᱟᱡ ᱧᱩᱛᱩᱢ᱾</value></prop></node><node oor:name="shipaddress"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱴᱷᱤᱠᱟᱹᱱᱟᱡᱟᱦᱟᱡ ᱴᱷᱤᱠᱟᱹᱱᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱴᱷᱤᱠᱟᱹᱱᱟᱡᱟᱦᱟᱡ ᱴᱷᱤᱠᱟᱹᱱᱟ</value></prop></node><node oor:name="shipcity"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱥᱮᱸᱲᱟ ᱥᱚᱦᱚᱨ᱾ᱡᱟᱦᱟᱡ ᱥᱮᱸᱲᱟ ᱥᱚᱦᱚᱨ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱥᱮᱸᱲᱟ ᱥᱚᱦᱚᱨ᱾ᱡᱟᱦᱟᱡ ᱥᱮᱸᱲᱟ ᱥᱚᱦᱚᱨ᱾</value></prop></node><node oor:name="shipstateorprovince"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱯᱚᱱᱚᱛ ᱟᱨ ᱵᱟᱝ ᱨᱟᱡᱡᱟᱦᱟᱡ ᱯᱚᱱᱚᱛ ᱟᱨ ᱵᱟᱝ ᱨᱟᱡ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱯᱚᱱᱚᱛ ᱨᱟᱡ (~w)ᱡᱟᱦᱟᱡ ᱯᱚᱱᱚᱛ ᱨᱟᱡ</value></prop></node><node oor:name="shippostalcode"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱰᱟᱠ ᱞᱮᱠᱷᱟ ᱪᱤᱱᱦᱟᱹᱡᱟᱦᱟᱡ ᱰᱟᱠ ᱞᱮᱠᱷᱟ ᱪᱤᱱᱦᱟᱹ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱰᱟᱠ ᱞᱮᱠᱷᱟ ᱪᱤᱱᱦᱟᱹᱡᱟᱦᱟᱡ ᱰᱟᱠ ᱞᱮᱠᱷᱟ ᱪᱤᱱᱦᱟᱹ</value></prop></node><node oor:name="shipcountryorregion"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱫᱤᱥᱚ़ᱢ ᱟᱨ ᱵᱟᱝ ᱴᱷᱚᱴᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱫᱤᱥᱚ़ᱢ  ᱴᱷᱚᱴᱟ</value></prop></node><node oor:name="shipphonenumber"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱥᱟᱸᱜᱤᱧ ᱜᱟᱞ ᱞᱮᱠᱷᱟᱡᱟᱦᱟᱡ ᱥᱟᱸᱜᱤᱧ ᱜᱟᱞ ᱞᱮᱠᱷᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱥᱟᱸᱜᱤᱧ ᱜᱟᱞ ᱞᱮᱠᱷᱟ  ᱾ᱠᱩᱞᱤᱡᱟᱜ ᱥᱟᱸᱜᱤᱧ ᱜᱟᱞ  ᱞᱮᱠᱷᱟ  ᱾</value></prop></node><node oor:name="shipdate"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱢᱟᱹᱦᱤᱫ᱾ᱡᱟᱦᱟᱡ ᱢᱟᱹᱦᱤᱫ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱢᱟᱹᱦᱤᱫ᱾ᱡᱟᱦᱟᱡ ᱢᱟᱹᱦᱤᱫ ᱾</value></prop></node><node oor:name="shippingmethodID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱣᱤᱫᱷᱟᱱ ID</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱦᱟᱡ ᱢᱟᱹᱦᱤᱫ ID</value></prop></node><node oor:name="freightcharge"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱵᱚᱡᱷᱟ ᱜᱚᱱᱚᱝ ᱾ᱵᱷᱟᱲᱟ ᱜᱚᱱᱚᱝ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱵᱚᱡᱷᱟ ᱜᱚᱱᱚᱝ ᱾ᱵᱷᱟᱲᱟ ᱜᱚᱱᱚᱝ ᱾</value></prop></node><node oor:name="salestaxrate"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱟᱠᱷᱨᱤᱭ ᱢᱟᱹᱥᱩᱞ ᱫᱚᱨᱟᱠᱷᱨᱤᱭ ᱢᱟᱹᱥᱩᱞ ᱫᱚᱨ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱟᱠᱷᱨᱤᱧ ᱢᱟᱹᱥᱩᱞ ᱫᱚᱨᱟᱠᱷᱨᱤᱧ ᱢᱟᱹᱥᱩᱞ ᱫᱚᱨ</value></prop></node></node></node><node oor:name="orderdetails"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱚᱨᱢᱟᱥ ᱵᱤᱵᱨᱚᱱᱯᱚᱨᱢᱟᱥ ᱵᱤᱵᱨᱚᱱ</value></prop><node oor:name="Fields"><node oor:name="orderdetailID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱚᱨᱢᱟᱥ ᱵᱤᱵᱨᱚᱱ ID</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱯᱚᱨᱢᱟᱥ ᱵᱤᱵᱨᱚᱱ ID</value></prop></node><node oor:name="orderID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱛᱷᱟᱨ ᱠᱚ ID᱾ᱯᱚᱨᱢᱟᱥ ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱛᱷᱟᱨ ᱠᱚ ID᱾ᱯᱚᱨᱢᱟᱥ ID᱾</value></prop></node><node oor:name="productID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱨᱚᱰᱟᱠᱴ ᱟᱭᱤ ᱰᱤ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱯᱨᱚᱰᱟᱠᱴ ᱟᱭᱤ ᱰᱤ</value></prop></node><node oor:name="datesold"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱫ ᱟᱠᱷᱨᱤᱧ᱾ᱢᱟᱹᱦᱤᱫ ᱟᱠᱷᱨᱤᱧ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱫ ᱟᱠᱷᱨᱤᱧ᱾ᱢᱟᱹᱦᱤᱫ ᱟᱠᱷᱨᱤᱧ᱾</value></prop></node><node oor:name="quantity"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱯᱚᱨᱤᱢᱟᱱ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱯᱚᱨᱤᱢᱟᱱ</value></prop></node><node oor:name="unitprice"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱮᱞᱮᱠᱷ ᱜᱚᱱᱚᱝ ᱾ (~m)ᱮᱞᱮᱠᱷ ᱜᱚᱱᱚᱝ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱮᱞᱮᱠᱷ ᱜᱚᱱᱚᱝ ᱾ (~m)ᱮᱞᱮᱠᱷ ᱜᱚᱱᱚᱝ᱾</value></prop></node><node oor:name="discount"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱪᱷᱩᱴ</value></