rop oor:name="Name"><value xml:lang="sat-Olck">ᱛᱷᱟᱹᱨᱤ ᱵᱟᱹᱴᱤ ᱥᱟᱯᱟᱯ ᱠᱚ᱾ (~e)ᱛᱷᱟᱹᱨᱤ ᱵᱟᱹᱴᱤ ᱥᱟᱯᱟᱯ ᱠᱚ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱛᱷᱟᱹᱨᱤ ᱵᱟᱹᱴᱤ ᱥᱟᱯᱟᱯ ᱠᱚ᱾ (~e)ᱛᱷᱟᱹᱨᱤ ᱵᱟᱹᱴᱤ ᱥᱟᱯᱟᱯ ᱠᱚ᱾</value></prop></node><node oor:name="notes"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱱᱚᱴᱥ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱱᱚᱴᱥ</value></prop></node></node></node><node oor:name="plants"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱫᱟᱨᱮ ᱠᱚᱫᱟᱨᱮ ᱠᱚ</value></prop><node oor:name="Fields"><node oor:name="plantID"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱫᱟᱨᱮ ᱠᱚ ID᱾ᱫᱟᱨᱮ ID᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱫᱟᱨᱮ ᱠᱚ ID᱾ᱫᱟᱨᱮ ID᱾</value></prop></node><node oor:name="commonname"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱚᱢᱟᱱ ᱧᱩᱛᱩᱢ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱚᱢᱟᱱ ᱧᱩᱛᱩᱢ ᱾</value></prop></node><node oor:name="genus"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱡᱟᱹᱛᱤ ᱠᱚ ᱾ᱡᱟᱹᱛᱤ ᱠᱚ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱡᱟᱹᱛᱤ ᱠᱚ ᱾ᱡᱟᱹᱛᱤ ᱠᱚ ᱾</value></prop></node><node oor:name="species"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱜᱩᱥᱴᱤ ᱠᱚ ᱾ᱜᱩᱥᱴᱤ ᱠᱚ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱜᱩᱥᱴᱤ ᱠᱚ ᱾ᱜᱩᱥᱴᱤ ᱠᱚ᱾</value></prop></node><node oor:name="flowering"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱵᱟᱦᱟᱜᱟᱜ ᱾ᱵᱟᱦᱟᱜᱟᱜ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱵᱟᱦᱟᱜᱟᱜ ᱾ᱵᱟᱦᱟᱜᱟᱜ᱾</value></prop></node><node oor:name="lightpreference"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱩᱥᱤᱭᱟᱜ ᱢᱟᱨᱥᱟᱞᱠᱩᱥᱤᱭᱟᱜ ᱢᱟᱨᱥᱟᱞ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱢᱟᱨᱥᱟᱞ ᱯᱨᱮᱯᱷ</value></prop></node><node oor:name="temperaturepreference"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱩᱥᱤᱭᱟᱜ  ᱩᱨᱜᱩᱢᱠᱩᱥᱤᱭᱟᱜ  ᱩᱨᱜᱩᱢ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱩᱥᱤᱭᱟᱜ  ᱩᱨᱜᱩᱢᱠᱩᱥᱤᱭᱟᱜ  ᱩᱨᱜᱩᱢ</value></prop></node><node oor:name="fertilizefrequency"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱵᱚᱨᱟᱵᱚᱨ ᱠᱷᱚᱛᱵᱚᱨᱟᱵᱚᱨ ᱠᱷᱚᱛ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱵᱚᱨᱟᱵᱚᱨ ᱠᱷᱚᱛ</value></prop></node><node oor:name="wateringfrequency"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱵᱚᱨᱟᱵᱚᱨ ᱫᱟᱜᱵᱚᱨᱟᱵᱚᱨ ᱫᱟᱜ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱵᱚᱨᱟᱵᱚᱨ ᱫᱟᱜᱵᱚᱨᱟᱵᱚᱨ ᱫᱟᱜ</value></prop></node><node oor:name="datepurchased"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱟᱹᱦᱤᱛ ᱠᱤᱨᱤᱧ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱵᱚᱨᱟᱵᱚᱨ ᱢᱟᱹᱦᱤᱫ᱾ᱵᱚᱨᱟᱵᱚᱨ ᱢᱟᱹᱦᱤᱫ᱾</value></prop></node><node oor:name="placepurchased"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱤᱨᱤᱧ ᱡᱟᱭᱜᱟ᱾ᱠᱤᱨᱤᱧ ᱡᱟᱭᱜᱟ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱤᱨᱤᱧ ᱢᱟᱹᱦᱤᱫ ᱾ (~m)ᱠᱤᱨᱤᱧ ᱡᱟᱭᱜᱟ ᱾</value></prop></node><node oor:name="dateplanted"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱨᱚᱦᱚᱭ ᱢᱟᱹᱦᱤᱫ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱨᱚᱦᱚᱭ ᱢᱟᱹᱦᱤᱫᱨᱚᱦᱚᱭ ᱢᱟᱹᱦᱤᱫ</value></prop></node><node oor:name="daterepotted"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱞᱟᱹᱭ ᱩᱫᱩᱠ ᱥᱚᱫᱚᱨ ᱢᱟᱹᱦᱤᱫᱞᱟᱹᱭ ᱩᱫᱩᱠ ᱥᱚᱫᱚᱨ ᱢᱟᱹᱦᱤᱫ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱞᱟᱹᱭ ᱩᱫᱩᱠ ᱥᱚᱫᱚᱨ ᱢᱟᱹᱦᱤᱫᱞᱟᱹᱭ ᱩᱫᱩᱠ ᱥᱚᱫᱚᱨ ᱢᱟᱹᱦᱤᱫ</value></prop></node><node oor:name="datepruned"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱦᱮᱥᱮ ᱢᱟᱹᱦᱤᱫ ᱾ᱦᱮᱥᱮ ᱢᱟᱹᱦᱤᱫ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱦᱮᱥᱮ ᱢᱟᱹᱦᱤᱫ ᱾ᱦᱮᱥᱮ ᱢᱟᱹᱦᱤᱫ᱾</value></prop></node><node oor:name="datewatered"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱫᱟᱜ ᱮᱢᱢᱟᱹᱦᱤᱫᱫᱟᱜ ᱮᱢᱢᱟᱹᱦᱤᱫ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱫᱟᱜ ᱮᱢᱢᱟᱹᱦᱤᱫᱫᱟᱜ ᱮᱢᱢᱟᱹᱦᱤᱫ</value></prop></node><node oor:name="photo"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱚᱦᱚᱨ ᱪᱤᱛᱟᱹᱨ᱾ᱢᱚᱦᱚᱨ ᱪᱤᱛᱟᱹᱨ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱢᱚᱦᱚᱨ ᱪᱤᱛᱟᱹᱨ᱾ᱢᱚᱦᱚᱨ ᱪᱤᱛᱟᱹᱨ᱾</value></prop></node><node oor:name=