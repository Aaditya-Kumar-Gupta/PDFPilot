name="referencenumber"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱞᱟᱹᱭ ᱩᱫᱩᱠ ᱞᱮᱠᱷᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱞᱟᱹᱭ ᱩᱫᱩᱠ ᱞᱮᱠᱷᱟᱞᱟᱹᱭ ᱩᱫᱩᱠ ᱞᱮᱠᱷᱟ</value></prop></node><node oor:name="numberofunits"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱮᱞᱮᱠᱷ ᱨᱮᱭᱟᱜ ᱞᱮᱠᱷᱟᱮᱞᱮᱠᱷ ᱨᱮᱭᱟᱜ ᱞᱮᱠᱷᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱞᱟᱹᱭ ᱩᱫᱩᱠ ᱞᱮᱠᱷᱟᱞᱟᱹᱭ ᱩᱫᱩᱠ ᱞᱮᱠᱷᱟ</value></prop></node><node oor:name="withdrawalamount"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠ़ᱣᱲᱤ ᱳᱰᱚᱠᱠ़ᱣᱲᱤ ᱳᱰᱚᱠ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠ़ᱣᱲᱤ ᱳᱰᱚᱠᱠ़ᱣᱲᱤ ᱳᱰᱚᱠ</value></prop></node><node oor:name="depositamount"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱚᱣᱲᱤ ᱡᱚᱢᱟᱠᱚᱣᱲᱤ ᱡᱚᱢᱟ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱚᱣᱲᱤ ᱡᱚᱢᱟᱠᱚᱣᱲᱤ ᱡᱚᱢᱟ</value></prop></node><node oor:name="interestearned"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱥᱩᱫ ᱟᱨᱡᱟᱣᱥᱩᱫ ᱟᱨᱡᱟᱣ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱥᱩᱫ ᱟᱨᱡᱟᱣᱥᱩᱫ ᱟᱨᱡᱟᱣ</value></prop></node><node oor:name="buyselldate"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱤᱨᱤᱧ ᱟᱠᱷᱨᱤᱧᱠᱤᱨᱤᱧ ᱟᱠᱷᱨᱤᱧ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱤᱨᱤᱧ ᱟᱠᱷᱨᱤᱧᱠᱤᱨᱤᱧ ᱟᱠᱷᱨᱤᱧ</value></prop></node><node oor:name="buysellprice"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱤᱨᱤᱧ ᱟᱠᱷᱨᱤᱧ  ᱜᱚᱱᱚᱝ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱤᱨᱤᱧ ᱟᱠᱷᱨᱤᱧ  ᱜᱚᱱᱚᱝᱠᱤᱨᱤᱧ ᱟᱠᱷᱨᱤᱧ  ᱜᱚᱱᱚᱝ</value></prop></node><node oor:name="servicecharge"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱠᱟᱹᱢᱤ ᱜᱚᱱᱚᱝᱠᱟᱹᱢᱤ ᱜᱚᱱᱚᱝ</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱠᱟᱹᱢᱤ ᱜᱚᱱᱚᱝ (~n)ᱠᱟᱹᱢᱤ ᱜᱚᱱᱚᱝ</value></prop></node><node oor:name="taxable"><prop oor:name="Name"><value xml:lang="sat-Olck">ᱢᱟᱹᱥᱩᱞ ᱫᱟᱲᱮᱭᱟᱠ ᱾ᱢᱟᱹᱥᱩᱞ ᱫᱟᱲᱮᱭᱟᱠ ᱾</value></prop><prop oor:name="ShortName"><value xml:lang="sat-Olck">ᱢᱟᱹᱥᱩᱞ ᱫᱟᱲᱮᱭᱟᱠ ᱾ᱢᱟᱹᱥᱩᱞ ᱫᱟᱲᱮᱭᱟᱠ ᱾</value></prop></node><node oor:name="notes"><prop oo