p://openoffice.org/2004/installation" oor:package="org.openoffice.Office" oor:name="PresenterScreen"><node oor:name="PresenterScreenSettings"><node oor:name="ToolBars"><node oor:name="ToolBar"><node oor:name="Entries"><node oor:name="a"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="lo">ກ່ອນໜ້ານີ້</value></prop></node></node><node oor:name="b"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="lo">ຖັດໄປ</value></prop></node></node><node oor:name="c"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="lo">ໝາຍເຫດ</value></prop></node></node><node oor:name="d"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="lo">ສະໄລ້</value></prop></node></node><node oor:name="k"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="lo">Pause</value></prop></node><node oor:name="Selected"><prop oor:name="Text"><value xml:lang="lo">Resume</value></prop></node><node oor:name="MouseOverSelected"><prop oor:name="Text"><value xml:lang="lo">Resume</value></prop></node></node><node oor:name="l"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="lo">Restart</value></prop></node></node><node oor:name="n"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="lo">Exchange</value></prop></node></node><node oor:name="p"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="lo">Help</value></prop></node></node><node oor:name="r"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="lo">Exit</value></prop></node></node></node></node><node oor:name="NotesToolBar"><node oor:name="Entries"><node oor:name="a"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="lo">ຂະຫຍາຍເຂົ້າ</value></prop></node></node></node></node></node><node oor:name="Buttons"><node oor:name="SlideSorterCloser"><prop oor:name="Text"><value xml:lang="lo">ປິດ</value></prop></node><node oor:name="NotesViewCloser"><prop oor:name="Text"><value xml:lang="lo">ປິດ</value></prop></node><node oor:name="HelpViewCloser"><prop oor:name="Text"><value xml:lang="lo">ປິດ</value></prop></node></node><node oor:name="HelpView"><node oor:name="HelpStrings"><node oor:name="a"><prop oor:name="Left"><value xml:lang="lo">Left click, right or down arrow, spacebar, page down, enter, return</value></prop><prop oor:name="Right"><value xml:lang="lo">ສະໄລ້ຖັດໄປ, ການສະແດງເອັຟເຝັກຖັດໄປ</value></prop></node><node oor:name="b"><prop oor:name="Left"><value xml:lang="lo">Right click, left or up arrow, page up, backspace</value></prop><prop oor:name="Right"><value xml:lang="lo">ສະໄລ້ກ່ອນໜ້າ, ຫຼື ການສະແດງເອັຟເຝັກກ່ອນໜ້າ</value></prop></node><node oor:name="c"><prop oor:name="Left"><value xml:lang="lo">'P'</value></prop><prop oor:name="Right"><value xml:lang="lo">Use mouse pointer as pen</value></prop></node><node oor:name="d"><prop oor:name="Left"><value xml:lang="lo">ປຸ່ມ Home</value></prop><prop oor:name="Right"><value xml:lang="lo">ສະໄລ້ທຳອິດ</value></prop></node><node oor:name="e"><prop oor:name="Left"><value xml:lang="lo">ປຸ່ມ End</value></prop><prop oor:name="Right"><value xml:lang="lo">ສະໄລ້ສຸດທ້າຍ</value></prop></node><node oor:name="f"><prop oor:name="Left"><value xml:lang="lo">'E'</value></prop><prop oor:name="Right"><value xml:lang="lo">Erase all ink on slide</value></prop></node><node oor:name="g"><prop oor:name="Left"><value xml:lang="lo">Alt-Page Up</value></prop><prop oor:name="Right"><value xml:lang="lo">ສະໄລ້ກ່ອນໜ້າໂດຍບໍ່ສະແດງເອັຟເຝັກ</value></prop></node><node oor:name="h"><prop oor:name="Left"><value xml:lang="lo">Alt-Page Down</value></prop><prop oor:name="Right"><value xml:lang="lo">ສະໄລ້ຖັດໄປໂດຍບໍ່ສະແດງເອັຟເຝັກ</value></prop></node><node oor:name="j"><prop oor:name="Left"><value xml:lang="lo">'B', '.'</value></prop><prop oor:name="Right"><value xml:lang="lo">ເຮັດໃຫ້ຈໍພາບດຳ/ເຊົາດຳ</value></prop></node><node oor:name="k"><prop oor:name="Left"><value xml:lang="lo">'W', ','</value></prop><prop oor:name="Right"><value xml:lang="lo">ເຮັດໃຫ້ຈໍພາບຂາວ/ເຊົາຂາວ</value></prop></node><node oor:name="m"><prop oor:name="Left"><value xml:lang="lo">Esc, '-'</value></prop><prop oor:name="Right"><value xml:lang="lo">ສິ້ນສຸດການນຳສະເໜີສະໄລ້</value></prop></node><node oor:name="o"><prop oor:name="Left"><value xml:lang="lo">ຕົວເລກຕາມດ້ວຍປຸ່ມ Enter</value></prop><prop oor:name="Right"><value xml:lang="lo">ໄປຍັງສະໄລ້ນັ້ນ</value></prop></node><node oor:name="q"><prop oor:name="Left"><value xml:lang="lo">'G', 'S'</value></prop><prop oor:name="Right"><value xml:lang="lo">ຂະຫຍາຍ/ຫຍໍ້ຂະໜາດຂອງຕົວອັກສອນໝາຍເຫດ</value></prop></node><node oor:name="r"><prop oor:name="Left"><value xml:lang="lo">'A', 'Z'</value></prop><prop oor:name="Right"><value xml:lang="lo">ເລື່ອນໝາຍເຫດຂື້ນ/ລົງ</value></prop></node><node oor:name="s"><prop oor:name="Left"><value xml:lang="lo">'H', 'L'</value></prop><prop oor:name="Right"><value xml:lang="lo">ຍ້າຍເຄື່ອງໝາຍດາວໃນໝາຍເຫດ ໄປຂ້າງຫຼັງ/ຂ້າງໜ້າ</value></prop></node><node oor:name="u"><prop oor:name="Left"><value xml:lang="lo">Ctrl-'1'</value></prop><prop oor:name="Right"><value xml:lang="lo">ສະແດງຈໍຂອງຜູ້ນຳສະເໜີ</value></prop></node><node oor:name="v"><prop oor:name="Left"><value xml:lang="lo">Ctrl-'2'</value></prop><prop oor:name="Right"><value xml:lang="lo">ສະແດງບັນທຶກສຳລັບການນຳສະເໜີ</value></prop></node><node oor:name="w"><prop oor:name="Left"><value xml:lang="lo">Ctrl-'3'</value></prop><prop oor:name="Right"><value xml:lang="lo">ສະແດງພາບໂດຍລວມຂອງສະໄລ້</value></prop></node><node oor:name="x"><prop oor:name="Left"><value xml:lang="lo">Ctrl-'4'</value></prop><prop oor:name="Right"><value xml:lang="lo">ສະລັບຈໍພາບ</value></prop></node><node oor:name="z"><prop oor:name="Left"><value xml:lang="lo">Ctrl-'A'</value></prop><prop oor:name="Right"><value xml:lang="lo">Turn off pointer as pen mode</value></prop></node></node></node></node><node oor:name="Presenter"><node oor:name="Views"><node oor:name="CurrentSlidePreview"><prop oor:name="Title"><value xml:lang="lo">ສະໄລ້ປັດຈຸບັນ (%CURRENT_SLIDE_NUMBER% ຈາກ %SLIDE_COUNT%)</value></prop><prop oor:name="AccessibleTitle"><value xml:lang="lo">Current Slide (%CURRENT_SLIDE_NUMBER% of %SLIDE_COUNT%), %CURRENT_SLIDE_NAME%</value></prop><node oor:name="Strings"><node oor:name="ClickToExitPresentationText"><prop oor:name="String"><value xml:lang="lo">ກົດເພື່ອອອກຈາກການນຳສະເໜີ...</value></prop></node><node oor:name="ClickToExitPresentationTitle"><prop oor:name="String"><value xml:lang="lo">ສະໄລ້ປັດຈຸບັນ (ສິ້ນສຸດ)</value></prop></node></node></node><node oor:name="NextSlidePreview"><prop oor:name="Title"><value xml:lang="lo">ສະໄລ້ຖັດໄປ</value></prop></node><node oor:name="NotesView"><prop oor:name="Title"><value xml:lang="lo">ໝາຍເຫດ</value></prop></node><node oor:name="SlideSorter"><prop oor:name="AccessibleTitle"><value xml:lang="lo">ພາບໂດຍລວມຂອງສະໄລ້, %CURRENT_SLIDE_NAME%, %CURRENT_SLIDE_NUMBER% ຈາກ %SLIDE_COUNT%</value></prop></node><node oor:name="HelpView"><prop oor:name="Title"><value xml:lang="lo">ຊ່ວຍເຫຼືອ</value></prop></node></node><node oor:name="Accessibility"><node oor:name="Console"><prop oor:name="String"><value xml:lang="lo">DUMMY_NO_MORE_USED</value></prop></node><node oor:name="Preview"><prop oor:name="String"><value xml:lang="lo">DUMMY_NO_MORE_USED</value></prop></node><node oor:name="Notes"><prop oor:name="String"><value xml:lang="lo">DUMMY_NO_MORE_USED</value></prop></node></node></node></oor:component-data><oor:component-data xmlns:install="http://openoffice.org/2004/installation" oor:name="TableWizard" oor:package="org.openoffice.Office"><node oor:name="TableWizard"><node oor:name="business"><prop oor:name="Name"><value xml:lang="lo">ທຸລະກິດ</value></prop><node oor:name="Tables"><node oor:name="categories"><prop oor:name="Name"><value xml:lang="lo">ໝວດໝູ່</value></prop><node oor:name="Fields"><node oor:name="categoryID"><prop oor:name="Name"><value xml:lang="lo">ລະຫັດໝວດໝູ່</value></prop><prop oor:name="ShortName"><value xml:lang="lo">ລະຫັດໝວດໝູ່</value></prop></node><node oor:name="categoryname"><prop oor:name="Name"><value xml:lang="lo">ຊື່ໝວດໝູ່</value></prop><prop oor:name