ableModeVariable"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຕາຕະລາງ: ປ່ຽນແປງໄດ້</value></prop></node><node oor:name=".uno:TextWrap"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ການຫໍ່ຂໍ້ຄວາມ...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ແກ້ໄຂ...</value></prop></node><node oor:name=".uno:GotoNextIndexMark"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ໄປຫາລາຍການດັດຊະນີຖັດໄປ</value></prop></node><node oor:name=".uno:GotoPrevIndexMark"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ໄປຫາລາຍການດັດຊະນີກ່ອນໜ້າ</value></prop></node><node oor:name=".uno:GotoNextTableFormula"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ໄປຫາສູດຕາຕະລາງຖັດໄປ</value></prop></node><node oor:name=".uno:GotoPrevTableFormula"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ໄປຫາສູດຕາຕະລາງກ່ອນໜ້າ</value></prop></node><node oor:name=".uno:GotoNextWrongTableFormula"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ໄປຫາສູດຕາຕະລາງທີ່ຜິດພາດຖັດໄປ</value></prop></node><node oor:name=".uno:GotoPrevWrongTableFormula"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ໄປຫາສູດຕາຕະລາງທີ່ຜິດພາດກ່ອນໜ້າ</value></prop></node><node oor:name=".uno:SelectTextMode"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ເລືອກຂໍ້ຄວາມ</value></prop></node><node oor:name=".uno:Ruler"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ໄມ້ບັນທັດ</value></prop></node><node oor:name=".uno:LineNumberingDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ການໃສ່ເລກແຖວ...</value></prop></node><node oor:name=".uno:ShowResolvedAnnotations"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ສະແດງຄຳເຫັນທີ່ແກ້ໄຂແລ້ວ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ຄຳເຫັນທີ່ແກ້ໄຂແລ້ວ</value></prop></node><node oor:name=".uno:ShowGraphics"><prop oor:name="