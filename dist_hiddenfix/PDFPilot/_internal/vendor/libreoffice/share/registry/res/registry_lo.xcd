rageDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຄ່າສະເລ່ຍເຄື່ອນທີ່...</value></prop></node><node oor:name=".uno:RegressionDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ການຖດຖອຍ...</value></prop></node><node oor:name=".uno:TTestDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ການທົດສອບ ~t-test ແບບຈັບຄູ່...</value></prop></node><node oor:name=".uno:FTestDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ການທົດສອບ ~F-test...</value></prop></node><node oor:name=".uno:ZTestDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ການທົດສອບ ~Z-test...</value></prop></node><node oor:name=".uno:ChiSquareTestDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ການທົດສອບ ~ໄຄສະແຄວ...</value></prop></node><node oor:name=".uno:FourierAnalysisDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ການວິເຄາະ~ຟູຣິເຢ...</value></prop></node><node oor:name=".uno:FormatSparklineMenu"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ສະປາກລາຍ</value></prop></node><node oor:name=".uno:InsertSparkline"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ສະປາກລາຍ...</value></prop></node><node oor:name=".uno:DeleteSparkline"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ລຶບສະປາກລາຍ</value></prop></node><node oor:name=".uno:DeleteSparklineGroup"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ລຶບກຸ່ມສະປາກລາຍ</value></prop></node><node oor:name=".uno:GroupSparklines"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຈັດກຸ່ມສະປາກລາຍ</value></prop></node><node oor:name=".uno:UngroupSparklines"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຍົກເລີກການຈັດກຸ່ມສະປາກລາຍ</value></prop></node><node oor:name=".uno:EditSparkline"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແກ້ໄຂສະປາກລາຍ...</value></prop></node><node oor:name=".uno:EditSparklineGroup"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແກ້ໄຂກຸ່ມສະປາກລາຍ...</value></prop></node><node oor:name=".uno:EditHeaderAndFooter"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~Headers and Footers...</value></prop></node><node oor:name=".uno:Validation"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຄວາມຖືກຕ້ອງ...</value></prop></node><node oor:name=".uno:CurrentValidation"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ການກວດສອບຄວາມຖືກຕ້ອງຂອງຂໍ້ມູນ...</value></prop></node><node oor:name=".uno:DeleteRows"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ລຶບແຖວ</value></prop></node><node oor:name=".uno:InsertCtrl"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກ</value></prop></node><node oor:name=".uno:InsCellsCtrl"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກເຊວ</value></prop></node><node oor:name=".uno:TraceChangeMode"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ບັນທຶກ</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ບັນທຶກການຕິດຕາມການປ່ຽນແປງ</value></prop></node><node oor:name=".uno:ShowChanges"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ສະແດງ...</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ສະແດງການຕິດຕາມການປ່ຽນແປງ</value></prop></node><node oor:name=".uno:DefineLabelRange"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ກຳນົດ~ປ້າຍ...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ປ້າຍ...</value></prop></node><node oor:name=".uno:NoteVisible"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ສະແດງຄຳເຫັນ</value></prop></node><node oor:name=".uno:ShowNote"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ສະແດງຄຳເຫັນ</value></prop></node><node oor:name=".uno:HideNote"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ເຊື່ອງຄຳເຫັນ</value></prop></node><node oor:name=".uno:ShowAllNotes"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ສະແດງຄຳເຫັນທັງໝົດ</value></prop></node><node oor:name=".uno:HideAllNotes"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ເຊື່ອງຄຳເຫັນທັງໝົດ</value></prop></node><node oor:name=".uno:DeleteAllNotes"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ລຶບຄຳເຫັນທັງໝົດ</value></prop></node><node oor:name=".uno:DeleteNote"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">Delete Comment</value></prop></node><node oor:name=".uno:InputLineVisible"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ແຖບສູດ</value></prop></node><node oor:name=".uno:ViewRowColumnHeaders"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ເບິ່ງສ່ວນຫົວ</value></prop></node><node oor:name=".uno:Scale"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ມາດຕາສ່ວນການສະແດງຜົນໜ້າຈໍ</value></prop></node><node oor:name=".uno:ViewValueHighlighting"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ການເນັ້ນຄ່າ</value></prop></node><node oor:name=".uno:HandleDuplicateRecords"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຂໍ້ມູນຊ້ຳ...</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ເອົາອອກ ຫຼື ເລືອກລາຍການທີ່ຊ້ຳກັນຈາກການເລືອກ</value></prop></node><node oor:name=".uno:ViewColumnRowHighlighting"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ການເນັ້ນ ຖັນ/ແຖວ</value></prop></node><node oor:name=".uno:ViewHiddenColRow"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ສະແດງຕົວຊີ້ບອກ ແຖວ/ຖັນ ທີ່ຖືກເຊື່ອງ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ຕົວຊີ້ບອກ ແຖວ/ຖັນ ທີ່ຖືກເຊື່ອງ</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ສະແດງຕົວຊີ້ບອກສຳລັບແຖວ ແລະ ຖັນທີ່ຖືກເຊື່ອງໄວ້</value></prop></node><node oor:name=".uno:NormalViewMode"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ມຸມມອງ~ປົກກະຕິ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ປົກກະຕິ</value></prop></node><node oor:name=".uno:PagebreakMode"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~Page Break</value></prop></node><node oor:name=".uno:FunctionBox"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ລາຍການຟັງຊັນ</value></prop></node><node oor:name=".uno:DataAreaRefresh"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ໂຫຼດຂອບເຂດຄືນໃໝ່</value></prop></node><node oor:name=".uno:FocusCellAddress"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຊ່ອງປ້ອນຂໍ້ມູນພື້ນທີ່ແຜ່ນງານ</value></prop></node><node oor:name=".uno:Collaborate"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຮ່ວມມື...</value></prop></node><node oor:name=".uno:AcceptChanges"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຈັດການ...</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ຈັດການການຕິດຕາມການປ່ຽນແປງ</value></prop></node><node oor:name=".uno:CommentChange"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຄຳເຫັນ...</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ແຊກຄຳເຫັນການຕິດຕາມການປ່ຽນແປງ</value></prop></node><node oor:name=".uno:Delete"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ລ້າງເຊວ...</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">Cl~ear Contents...</value></prop></node><node oor:name=".uno:DeleteAllBreaks"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ລຶບການແບ່ງໜ້າ</value></prop></node><node oor:name=".uno:InsertRowBreak"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກ~ການແບ່ງແຖວ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ການແບ່ງແຖວ</value></prop></node><node oor:name=".uno:InsertColumnBreak"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກ~ການແບ່ງຖັນ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~Column Break</value></prop></node><node oor:name=".uno:AdjustPrintZoom"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ປັບມາດຕາສ່ວນ</value></prop></node><node oor:name=".uno:DeleteRowbreak"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ເອົາ~ການແບ່ງແຖວອອກ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ການແບ່ງແຖວ</value></prop></node><node oor:name=".uno:ResetPrintZoom"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຕັ້ງຄ່າມາດຕາສ່ວນຄືນໃໝ່</value></prop></node><node oor:name=".uno:DeleteColumnbreak"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ເອົາ~ການແບ່ງຖັນອອກ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~Column Break</value></prop></node><node oor:name=".uno:InsertContents"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ວາງແບບພິເສດ</value></prop></node><node oor:name=".uno:InsertCell"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກ~ເຊວ...</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">~Insert...</value></prop></node><node oor:name=".uno:InsertRowsMenu"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">Insert ~Rows</value></prop></node><node oor:name=".uno:InsertColumnsMenu"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">Insert Co~lumns</value></prop></node><node oor:name=".uno:InsertRowsBefore"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກ~ແຖວດ້ານເທິງ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ແຖວ~ດ້ານເທິງ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ແຊກແຖວ~ເທິງ</value></prop></node><node oor:name=".uno:InsertColumnsBefore"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກ~ຖັນກ່ອນ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ຖັນ~ກ່ອນ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ແຊກຖັນ~ກ່ອນ</value></prop></node><node oor:name=".uno:InsertRowsAfter"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກ~ແຖວລຸ່ມ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ແຖວ~ລຸ່ມ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ແຊກແຖວ~ລຸ່ມ</value></prop></node><node oor:name=".uno:InsertColumnsAfter"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກ~ຖັນຫຼັງ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ຖັນ~ຫຼັງ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ແຊກຖັນ~ຫຼັງ</value></prop></node><node oor:name=".uno:Insert"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກ~ແຜ່ນງານ...</value></prop></node><node oor:name=".uno:InsertSheetFromFile"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກແຜ່ນ~ງານຈາກໄຟລ໌...</value></prop></node><node oor:name=".uno:AddName"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ກຳນົດຊື່...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ກຳນົດ...</value></prop></node><node oor:name=".uno:DefineName"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຈັດການຊື່...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ຈັດການ...</value></prop></node><node oor:name=".uno:DefineCurrentName"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຈັດການຊື່...</value></prop></node><node oor:name=".uno:InsertName"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ແຊກຊ່ວງທີ່ຕັ້ງຊື່ ຫຼື ສຳນວນ...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ຊ່ວງທີ່ຕັ້ງຊື່ ຫຼື ສຳນວນ...</value></prop></node><node oor:name=".uno:CreateNames"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ສ້າງຊື່...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ສ້າງ...</value></prop></node><node oor:name=".uno:ApplyNames"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ກຳນົດຊື່</value></prop></node><node oor:name=".uno:InsertCellsDown"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກເຊວລົງລຸ່ມ</value></prop></node><node oor:name=".uno:InsertCellsRight"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແຊກເຊວໄປທາງຂວາ</value></prop></node><node oor:name=".uno:FormatCellDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຮູບແບບ~ເຊວ...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ເຊ~ວ...</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">~ຮູບແບບເຊວ...</value></prop></node><node oor:name=".uno:RowHeight"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຄວາມ~ສູງແຖວ...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ຄວາມສູງ...</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ຄວາມ~ສູງແຖວ...</value></prop></node><node oor:name=".uno:SetOptimalRowHeight"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຄວາມສູງແຖວ~ທີ່ເໝາະສົມ...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ຄວາມສູງ~ທີ່ເໝາະສົມ...</value></prop></node><node oor:name=".uno:HideRow"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ເຊື່ອງແຖວ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ເຊື່ອງ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">~ເຊື່ອງແຖວ</value></prop></node><node oor:name=".uno:ShowRow"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ສະແດງແຖວ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ສະແດງ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ສະ~ແດງແຖວ</value></prop></node><node oor:name=".uno:ColumnWidth"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຄວາມ~ກວ້າງຖັນ...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ຄວາມກວ້າງ...</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ຄວາມ~ກວ້າງຖັນ...</value></prop></node><node oor:name=".uno:SetOptimalColumnWidth"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຄວາມກວ້າງຖັນ~ທີ່ເໝາະສົມ...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ຄວາມກວ້າງ~ທີ່ເໝາະສົມ...</value></prop></node><node oor:name=".uno:HideColumn"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ເຊື່ອງຖັນ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ເຊື່ອງ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">~ເຊື່ອງຖັນ</value></prop></node><node oor:name=".uno:ShowColumn"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ສະແດງຖັນ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ສະແດງ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">~ສະແດງຖັນ</value></prop></node><node oor:name=".uno:Hide"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ເຊື່ອງແຜ່ນງານ</value></prop></node><node oor:name=".uno:Show"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ສະແດງແຜ່ນງານ...</value></prop></node><node oor:name=".uno:SplitCell"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຍົກເລີກການຮວມເຊວ</value></prop></node><node oor:name=".uno:ToggleMergeCells"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຮວມ ແລະ ຈັດເຊວໄວ້ກາງ</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ຮວມ ແລະ ຈັດໄວ້ກາງ ຫຼື ຍົກເລີກການຮວມເຊວ ຂຶ້ນກັບສະຖານະການສະຫຼັບປັດຈຸບັນ</value></prop></node><node oor:name=".uno:PageFormatDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຮູບແບບ~ໜ້າ...</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">~ຮູບແບບໜ້າ...</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ຮູບແບບ~ໜ້າ...</value></prop></node><node oor:name=".uno:StandardTextAttributes"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຄຸນລັກສະນະຂໍ້ຄວາມມາດຕະຖານ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ຄ່າເລີ່ມຕົ້ນ</value></prop></node><node oor:name=".uno:TextAttributes"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຂໍ້ຄວາມ...</value></prop></node><node oor:name=".uno:SetOptimalColumnWidthDirect"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຄວາມກວ້າງຖັນທີ່ເໝາະສົມ, ໂດຍກົງ</value></prop></node><node oor:name=".uno:AutomaticCalculation"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຄິດໄລ່ອັດຕະໂນມັດ</value></prop></node><node oor:name=".uno:Calculate"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຄິດໄລ່ຄືນໃໝ່</value></prop></node><node oor:name=".uno:Protect"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ປ້ອງກັນ~ແຜ່ນງານ...</value></prop></node><node oor:name=".uno:ToolProtectionDocument"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ປ້ອງກັນໂຄງສ້າງ~ສະເປຣດຊີດ...</value></prop></node><node oor:name=".uno:ScenarioManager"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ສະຖານະການ...</value></prop></node><node oor:name=".uno:RecalcPivotTable"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ໂຫຼດຕາຕະລາງພິວອດຄືນໃໝ່</value><