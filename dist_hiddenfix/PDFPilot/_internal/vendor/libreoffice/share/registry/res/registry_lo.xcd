lue xml:lang="lo">ໃຊ້ເມນູປ໊ອບອັບຂັ້ນສູງເພື່ອສ້າງສ່ວນຫົວ/ສ່ວນຕີນໃນທັນທີ</value></prop></node><node oor:name=".uno:ShowOutlineContentVisibilityButton"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ສະແດງປຸ່ມພັບໂຄງຮ່າງ</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ສະແດງປຸ່ມຖັດຈາກຫົວຂໍ້ ແລະ ຫົວຂໍ້ຍ່ອຍເພື່ອຊ່ວຍໃນການພັບໂຄງຮ່າງ. ເຖິງວ່າບໍ່ມີປຸ່ມນີ້, ເຈົ້າກໍສາມາດພັບໂຄງຮ່າງດ້ວຍຕົວນຳທາງໄດ້.</value></prop></node><node oor:name=".uno:OutlineLevelsShown"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ສະແດງຈົນເຖິງລະດັບໂຄງຮ່າງ...</value></prop></node><node oor:name=".uno:HighlightCharDF"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ເນັ້ນການຈັດຮູບແບບຕົວອັກສອນໂດຍກົງ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ການຈັດຮູບແບບຕົວອັກສອນໂດຍກົງ</value></prop></node><node oor:name=".uno:SpotlightParaStyles"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ເນັ້ນຮູບແບບຫຍໍ້ໜ້າ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ຮູບແບບຫຍໍ້ໜ້າ</value></prop></node><node oor:name=".uno:SpotlightCharStyles"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ເນັ້ນຮູບແບບຕົວອັກສອນ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ຮູບແບບຕົວອັກສອນ</value></prop></node><node oor:name=".uno:ShowChangesInMargin"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ສະແດງການລຶບທີ່ຕິດຕາມໄວ້ໃນຂອບໜ້າ</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ສະແດງການລຶບທີ່ຕິດຕາມໄວ້ໃນຂອບໜ້າ</value></prop></node><node oor:name=".uno:GotoPage"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ໄປທີ່~ໜ້າ...</value></prop></node><node oor:name=".uno:CommentChangeTracking"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຄຳເຫັນ...</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ແຊກຄຳເຫັນສຳລັບການປ່ຽນແປງທີ່ຕິດຕາມ</value></prop></node><node oor:name=".uno:UpdateAll"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ປັບປຸງທັງໝົດ</value></prop></node><node oor:name=".uno:InsertEnvelope"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຊອງຈົດໝາຍ...</value></prop></node><node oor:name=".uno:AcceptTrackedChanges"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ຈັດການ...</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ຈັດການການປ່ຽນແປງທີ່ຕິດຕາມ</value></prop></node><node oor:name=".uno:EditCurIndex"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ແກ້ໄຂດັດສະນີ</value></prop></node><node oor:name=".uno:AuthoritiesEntryDialog"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~ການອ້າງອີງ...</value></prop></node><node oor:name=".uno:UpdateCharts"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">~Charts</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ປັບປຸງ~ແຜນວາດ</value></prop></node><node oor:name=".uno:InsertBookmark"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ການ~ໝາຍ...</value></prop><prop oor:name="TooltipLabel" oor:type="xs:string"><value xml:lang="lo">ແຊກການໝາຍ</value></prop></node><node oor:name=".uno:ContentControlProperties"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ຄຸນສົມບັດການຄວບຄຸມເນື້ອຫາ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ຄຸນສົມບັດ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ຄຸນສົມບັດການຄວບຄຸມເນື້ອຫາ</value></prop></node><node oor:name=".uno:DeleteContentControl"><prop oor:name="Label" oor:type="xs:string"><value xml:lang="lo">ລຶບການຄວບຄຸມເນື້ອຫາ</value></prop><prop oor:name="ContextLabel" oor:type="xs:string"><value xml:lang="lo">ລຶບການຄວບຄຸມເນື້ອຫາ</value></prop><prop oor:name="PopupLabel" oor:type="xs:string"><value xml:lang="lo">ລຶບ