><oor:component-data xmlns:install="http://openoffice.org/2004/installation" oor:package="org.openoffice.Office" oor:name="PresenterScreen"><node oor:name="PresenterScreenSettings"><node oor:name="ToolBars"><node oor:name="ToolBar"><node oor:name="Entries"><node oor:name="a"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="ab">Аԥхьатәи</value></prop></node></node><node oor:name="b"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="ab">Анаҩстәи</value></prop></node></node><node oor:name="c"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="ab">Азгәаҭақәа</value></prop></node></node><node oor:name="d"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="ab">Аслаидқәа</value></prop></node></node><node oor:name="k"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="ab">Апауза</value></prop></node><node oor:name="Selected"><prop oor:name="Text"><value xml:lang="ab">Анагӡара иацҵатәуп</value></prop></node><node oor:name="MouseOverSelected"><prop oor:name="Text"><value xml:lang="ab">Анагӡара иацҵатәуп</value></prop></node></node><node oor:name="l"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="ab">Аиҭадәықәҵара</value></prop></node></node><node oor:name="n"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="ab">Аиҭныԥсахлара</value></prop></node></node><node oor:name="p"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="ab">Аилыркаага</value></prop></node></node><node oor:name="r"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="ab">Аҭыҵырҭа</value></prop></node></node></node></node><node oor:name="NotesToolBar"><node oor:name="Entries"><node oor:name="a"><node oor:name="Normal"><prop oor:name="Text"><value xml:lang="ab">Амасштаб</value></prop></node></node></node></node></node><node oor:name="Buttons"><node oor:name="SlideSorterCloser"><prop oor:name="Text"><value xml:lang="ab">Иарктәуп</value></prop></node><node oor:name="NotesViewCloser"><prop oor:name="Text"><value xml:lang="ab">Иарктәуп</value></prop></node><node oor:name="HelpViewCloser"><prop oor:name="Text"><value xml:lang="ab">Иарктәуп</value></prop></node></node><node oor:name="HelpView"><node oor:name="HelpStrings"><node oor:name="a"><prop oor:name="Left"><value xml:lang="ab">Аҳәынаԥ армарахьтәи акнопка ала ақәыӷәӷәара, ахыц арӷьарахь ма алада, абжьажьга, Page Down, Enter, Return</value></prop><prop oor:name="Right"><value xml:lang="ab">Анаҩстәи аслаид ма аеффект</value></prop></node><node oor:name="b"><prop oor:name="Left"><value xml:lang="ab">Аҳәынаԥ арӷьарахьтәи акнопка ала ақәыӷәӷәара, ахыц армарахь ма аҩада, Page Up, Backspace</value></prop><prop oor:name="Right"><value xml:lang="ab">Аԥхьатәи аслаид ма аеффект</value></prop></node><node oor:name="c"><prop oor:name="Left"><value xml:lang="ab">«P»</value></prop><prop oor:name="Right"><value xml:lang="ab">Ихархәатәуп аҳәынаԥ арбага акалам ҳасабла</value></prop></node><node oor:name="d"><prop oor:name="Left"><value xml:lang="ab">Аҩныҟа</value></prop><prop oor:name="Right"><value xml:lang="ab">Актәи аслаид</value></prop></node><node oor:name="e"><prop oor:name="Left"><value xml:lang="ab">Анҵәамҭа</value></prop><prop oor:name="Right"><value xml:lang="ab">Аҵыхәтәантәи аслаид</value></prop></node><node oor:name="f"><prop oor:name="Left"><value xml:lang="ab">«E»</value></prop><prop oor:name="Right"><value xml:lang="ab">Аслаид аҟны ианыхтәуп аҷышәрақәа зегьы</value></prop></node><node oor:name="g"><prop oor:name="Left"><value xml:lang="ab">Alt+Page Up</value></prop><prop oor:name="Right"><value xml:lang="ab">Аԥхьатәи аслаид аеффект ада</value></prop></node><node oor:name="h"><prop oor:name="Left"><value xml:lang="ab">Alt+Page Down</value></prop><prop oor:name="Right"><value xml:lang="ab">Анаҩстәи аслаид аеффект ада</value></prop></node><node oor:name="j"><prop oor:name="Left"><value xml:lang="ab">'B', '.'</value></prop><prop oor:name="Right"><value xml:lang="ab">Иаҿак./Иаҿых. аекран еиқәаҵәа</value></prop></node>